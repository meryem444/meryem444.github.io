function renderInventory(){
  const grid=document.getElementById('inventory-grid');
  const sections=[{key:'freezer',label:'Freezer'},{key:'fridge',label:'Fridge'},{key:'pantry',label:'Pantry'}];
  grid.innerHTML=sections.map(sec=>{
    const rows=(S.inventory[sec.key]||[]).map(item=>
      `<tr><td>${esc(item.name)}</td><td style="color:var(--text-light)">${esc(item.amount)} ${esc(item.unit)}</td><td><button class="inv-del-btn" onclick="delInv('${sec.key}','${item.id}')">×</button></td></tr>`
    ).join('');
    return`<div class="inv-card"><h3>${sec.label}</h3>
      <table class="inv-table"><thead><tr><th>Item</th><th>Qty</th><th></th></tr></thead><tbody>${rows}</tbody></table>
      <div class="inv-add-row">
        <input id="in-${sec.key}" placeholder="Item name" style="flex:2">
        <input id="ia-${sec.key}" placeholder="Qty" style="width:55px">
        <input id="iu-${sec.key}" placeholder="unit" style="width:50px">
        <button onclick="addInv('${sec.key}')">+ Add</button>
      </div></div>`;
  }).join('');
}
function addInv(sec){
  const name=document.getElementById(`in-${sec}`)?.value.trim();if(!name)return;
  S.inventory[sec].push({id:'i'+Date.now(),name,amount:document.getElementById(`ia-${sec}`)?.value.trim()||'',unit:document.getElementById(`iu-${sec}`)?.value.trim()||''});
  save();renderInventory();
}
function delInv(sec,id){S.inventory[sec]=S.inventory[sec].filter(i=>i.id!==id);save();renderInventory();}

