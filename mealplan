}

function bookRender(){
  bookState.filtered=bookApplyFilters();
  bookRenderActiveFilters();
  const total=bookState.filtered.length;
  const leftEl=document.getElementById('book-page-left');
  const rightEl=document.getElementById('book-page-right');

  if(bookState.tocMode){
    leftEl.innerHTML=bookRenderTOCLeftPage();
    rightEl.innerHTML=bookRenderTOCRightPage();
    document.getElementById('book-footer').textContent=total?`Table of Contents · ${total} recipe${total===1?'':'s'}`:'';
    document.querySelector('.book-arrow.left').disabled=true;
    document.querySelector('.book-arrow.right').disabled=total<=0;
  }else{
    if(bookState.spread>=total)bookState.spread=Math.max(0,total-1);
    const r=bookState.filtered[bookState.spread];
    if(r){
      leftEl.innerHTML=bookRenderLeftPage(r);
      rightEl.innerHTML=bookRenderRightPage(r);
    }else{
      leftEl.innerHTML=`<div style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--muted);font-style:italic;font-size:.85rem;text-align:center">no recipes match</div>`;
      rightEl.innerHTML='';
    }
    document.getElementById('book-footer').textContent=`Recipe ${bookState.spread+1} of ${total} · <span style="cursor:pointer;text-decoration:underline" onclick="bookGotoTOC()">Back to Contents</span>`;
    document.getElementById('book-footer').innerHTML=`Recipe ${bookState.spread+1} of ${total} · <span style="cursor:pointer;text-decoration:underline" onclick="bookGotoTOC()">Back to Contents</span>`;
    document.querySelector('.book-arrow.left').disabled=false; // can always go back to TOC
    document.querySelector('.book-arrow.right').disabled=bookState.spread>=total-1;
  }
  bookRenderRecs();
}
function bookFlip(direction){ // 'fwd' or 'bwd'
  if(bookState.animating)return;
  const total=bookState.filtered.length;
  if(total===0)return;

  // Determine current and next state
  // Virtual page sequence: [TOC] → [recipe 0] → [recipe 1] → ... → [recipe N-1]
  let curTOC=bookState.tocMode;
  let nextTOC=curTOC,nextSpread=bookState.spread;
  if(direction==='fwd'){
    if(curTOC){nextTOC=false;nextSpread=0}
    else if(bookState.spread<total-1){nextSpread=bookState.spread+1}
    else return; // already on last recipe
  }else{ // bwd
    if(curTOC)return; // can't go back from TOC
    if(bookState.spread===0){nextTOC=true;nextSpread=0}
    else{nextSpread=bookState.spread-1}
  }

  // Render snapshots for the flipper
  const renderRightFor=(toc,idx)=>toc?bookRenderTOCRightPage():bookRenderRightPage(bookState.filtered[idx]);
  const renderLeftFor=(toc,idx)=>toc?bookRenderTOCLeftPage():bookRenderLeftPage(bookState.filtered[idx]);

  bookState.animating=true;
  const flipper=document.getElementById('book-flipper');
  const front=document.getElementById('bf-front');
  const back=document.getElementById('bf-back');
  flipper.classList.remove('flip-fwd','flip-bwd');

  if(direction==='fwd'){
    front.innerHTML=renderRightFor(curTOC,bookState.spread);
    back.innerHTML=renderLeftFor(nextTOC,nextSpread);
    flipper.classList.add('show');
    requestAnimationFrame(()=>requestAnimationFrame(()=>flipper.classList.add('flip-fwd')));
  }else{
    front.innerHTML=renderLeftFor(curTOC,bookState.spread);
    back.innerHTML=renderRightFor(nextTOC,nextSpread);
    flipper.classList.add('show');
    requestAnimationFrame(()=>requestAnimationFrame(()=>flipper.classList.add('flip-bwd')));
  }
  setTimeout(()=>{
    bookState.tocMode=nextTOC;
    bookState.spread=nextSpread;
    flipper.classList.remove('show','flip-fwd','flip-bwd');
    bookState.animating=false;
    bookRender();
  },670);
}
function bookNext(){bookFlip('fwd')}
function bookPrev(){bookFlip('bwd')}

