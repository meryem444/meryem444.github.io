<script>
const MEALS=['breakfast','lunch','dinner']; // snacks moved to weekly
const MEAL_LABEL={breakfast:'Breakfast',lunch:'Lunch',dinner:'Dinner'};
const DAYS=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
const DAY_FULL=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
const PEOPLE=['meryem','austin','arya'];
const PERSON_LABEL={meryem:'Meryem',austin:'Austin',arya:'Arya'};

function pKey(w,d,m){return`${w}|${d}|${m}`}
function lKey(w,d,m,p){return`${w}|${d}|${m}|${p}`}
function bKey(w,d){return`b|${w}|${d}`}
function pidOf(recipeId,stepIdx,w,d,m){return`${recipeId}@${stepIdx}@${w}|${d}|${m}`}

function getWeekSunday(offset){
  const now=new Date(),d=new Date(now);
  d.setHours(0,0,0,0);d.setDate(d.getDate()-d.getDay()+(offset*7));return d;
}
function fmtDate(d){return d.toLocaleDateString('en-US',{month:'short',day:'numeric'})}
function todayStr(){const d=new Date();return`${d.getFullYear()}-${d.getMonth()}-${d.getDate()}`}
function dayStr(d){return`${d.getFullYear()}-${d.getMonth()}-${d.getDate()}`}

let S={};
function loadState(){
  try{const r=localStorage.getItem('mealplan_v3');if(r)return JSON.parse(r);}catch(e){}
  return makeDefault();
}
function save(){try{localStorage.setItem('mealplan_v3',JSON.stringify(S));}catch(e){}}

function migrateState(s){
  if(!s)return makeDefault();
  // Migrate timing -> batchable on recipe steps
  if(Array.isArray(s.recipes)){
    for(const r of s.recipes){
      if(Array.isArray(r.steps)){
        r.steps=r.steps.map(step=>{
          if(typeof step==='string')return{text:step,batchable:false};
          const next={...step};
          if(next.batchable===undefined){
            next.batchable=next.timing==='batch';
          }
          return next;
        });
      }
    }
  }
  // Migrate snacks meal slots → weekly snacks
  if(!s.weeklySnacks)s.weeklySnacks={};
  if(s.plan){
    for(const k of Object.keys(s.plan)){
      const parts=k.split('|');
      if(parts.length===3 && parts[2]==='snacks'){
        const w=parts[0];
        if(!s.weeklySnacks[w])s.weeklySnacks[w]=[];
        for(const e of (s.plan[k]||[])){
          if(!s.weeklySnacks[w].some(x=>x.recipeId===e.recipeId)){
            s.weeklySnacks[w].push({recipeId:e.recipeId});
          }
        }
        delete s.plan[k];
      }
    }
  }
  // v4 → v5: snacks are family-level (no person). Collapse {person, recipeId} → {recipeId}, dedup.
  for(const w of Object.keys(s.weeklySnacks||{})){
    const seen=new Set();
    const collapsed=[];
    for(const e of (s.weeklySnacks[w]||[])){
      if(!e || !e.recipeId)continue;
      if(seen.has(e.recipeId))continue;
      seen.add(e.recipeId);
      collapsed.push({recipeId:e.recipeId});
    }
    s.weeklySnacks[w]=collapsed;
  }
  if(!s.batchPlacements)s.batchPlacements={}; // bKey -> [pid,...]
  if(!s.batchCompleted)s.batchCompleted={};   // pid -> true (per-step completion, enables carry-forward)
  if(!s.prepDone)s.prepDone={};
  if(!s.customTasks)s.customTasks={};
  if(!s.shopping)s.shopping={};
  if(!s.logs)s.logs={};
  if(!s.inventory)s.inventory={freezer:[],fridge:[],pantry:[]};
  if(typeof s.weekOffset!=='number')s.weekOffset=0;
  return s;
}

function makeDefault(){
  return migrateState({
    weekOffset:0,plan:{},logs:{},prepDone:{},customTasks:{},shopping:{},
    weeklySnacks:{},batchPlacements:{},
    recipes:JSON.parse(JSON.stringify(DEFAULT_RECIPES)),
    // Inventory pulled from Notion Inventory DB on sync. Empty by default.
    inventory:{freezer:[],fridge:[],pantry:[]}
  });
}

let currentPage='plan',focusedDay=new Date().getDay();

function showPage(page,btn){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('page-'+page).classList.add('active');
  if(btn)btn.classList.add('active');
  currentPage=page;
  const showWeek=['plan','weekly-recipes','shopping'].includes(page);
  document.getElementById('week-nav-wrap').style.display=showWeek?'flex':'none';
  if(page==='plan')renderPlanPage();
  else if(page==='recipe-book')renderRecipeBook();
  else if(page==='weekly-recipes')renderWeeklyRecipes();
  else if(page==='shopping')renderShopping();
  else if(page==='inventory')renderInventory();
}
function changeWeek(delta){
  S.weekOffset+=delta;save();updateWeekLabel();
  if(currentPage==='plan')renderPlanPage();
  else if(currentPage==='weekly-recipes')renderWeeklyRecipes();
  else if(currentPage==='shopping')renderShopping();
}
function jumpToToday(){
  S.weekOffset=0;
  focusedDay=new Date().getDay();
  save();
  updateWeekLabel();
  if(currentPage==='plan')renderPlanPage();
  else if(currentPage==='weekly-recipes')renderWeeklyRecipes();
  else if(currentPage==='shopping')renderShopping();
}
function updateWeekLabel(){
  const sun=getWeekSunday(S.weekOffset),sat=new Date(sun);sat.setDate(sat.getDate()+6);
  const lbl=document.getElementById('week-label');
  lbl.textContent=`${fmtDate(sun)} – ${fmtDate(sat)}`;
  if(S.weekOffset===0){
    lbl.classList.add('current-week');
    lbl.title='This week';
  }else{
    lbl.classList.remove('current-week');
    lbl.title='Click to jump to this week';
  }
}

// ===== PLAN PAGE =====
function renderPlanPage(){
  renderPlanGrid();
  // Snacks now live inside the grid as the 4th row.
  // Batch tasks now flow through Daily Run (carry-forward + batch-ahead pills).
  renderDailyRunInline();
}

function renderPlanGrid(){
  const grid=document.getElementById('plan-grid');
  const sun=getWeekSunday(S.weekOffset),td=todayStr();
  let html='<div></div>';
  for(let d=0;d<7;d++){
    const dd=new Date(sun);dd.setDate(sun.getDate()+d);
    const isToday=dayStr(dd)===td;
    const isFocused=focusedDay===d;
    html+=`<div class="col-header${isToday?' today':''}${isFocused?' focused':''}" onclick="setFocusedDay(${d})">${DAYS[d]}<span class="day-num">${dd.getDate()}</span></div>`;
  }
  for(const meal of MEALS){
    html+=`<div class="row-label">${MEAL_LABEL[meal]}</div>`;
    for(let d=0;d<7;d++){
      const dd=new Date(sun);dd.setDate(sun.getDate()+d);
      const isToday=dayStr(dd)===td;
      const entries=S.plan[pKey(S.weekOffset,d,meal)]||[];
      html+=buildCell(d,meal,entries,isToday);
    }
  }
  // SNACKS row — one wide cell that spans all 7 day-columns
  html+=`<div class="row-label">Snacks</div>`;
  html+=buildSnacksRow();
  grid.innerHTML=html;
}

function buildSnacksRow(){
  const list=S.weeklySnacks[S.weekOffset]||[];
  const recipes=list.map(e=>S.recipes.find(x=>x.id===e.recipeId)).filter(Boolean);
  let inner='';
  if(!recipes.length){
    inner=`<div class="cell-empty-hint">+</div>`;
  }else{
    inner=`<div class="snacks-strip">`;
    for(const r of recipes.slice(0,12)){
      inner+=`<div class="snack-thumb" title="${esc(r.name)}">`;
      if(r.photo)inner+=`<img src="${r.photo}" alt="${esc(r.name)}">`;
      else inner+=`<div class="snack-thumb-name">${esc(r.name.slice(0,18))}</div>`;
      inner+=`</div>`;
    }
    inner+=`</div>`;
  }
  return`<div class="meal-cell snacks-row-cell ${recipes.length?'has-recipes':''}" style="grid-column: 2 / -1" onclick="openBookForSnacks()">${inner}</div>`;
}

function buildCell(dayIdx,meal,entries,isToday){
  const uids=[...new Set(entries.map(e=>e.recipeId))];
  const recipes=uids.map(id=>S.recipes.find(r=>r.id===id)).filter(Boolean);
  const persons=[...new Set(entries.map(e=>e.person))];
  const has=recipes.length>0;
  let inner='';
  if(has){
    inner+=`<div class="cell-photos count-${Math.min(recipes.length,6)}">`;
    for(const r of recipes.slice(0,6)){
      inner+='<div class="cell-photo-item">';
      if(r.photo)inner+=`<img src="${r.photo}" alt="${esc(r.name)}">`;
      else inner+=`<div class="recipe-name-small">${esc(r.name)}</div>`;
      inner+='</div>';
    }
    inner+='</div><div class="cell-person-dots">';
    for(const p of persons)inner+=`<div class="dot ${p}" title="${PERSON_LABEL[p]}"></div>`;
    inner+='</div>';
  }else{inner='<div class="cell-empty-hint">+</div>';}
  return`<div class="meal-cell${isToday?' today':''}${has?' has-recipes':''}" onclick="openBook(${dayIdx},'${meal}')">${inner}</div>`;
}

function setFocusedDay(d){
  focusedDay=d;
  renderPlanGrid();
  renderDailyRunInline();
}

// ===== BATCH ROW =====
function renderBatchRow(){
  const row=document.getElementById('batch-row');
  const sun=getWeekSunday(S.weekOffset),td=todayStr();
  let html='<div class="batch-row-label">Batch Cooking</div>';
  for(let d=0;d<7;d++){
    const dd=new Date(sun);dd.setDate(sun.getDate()+d);
    const isToday=dayStr(dd)===td;
    const placements=S.batchPlacements[bKey(S.weekOffset,d)]||[];
    const has=placements.length>0;
    let inner='';
    if(has){
      const previewSteps=placements.slice(0,3).map(p=>resolveStep(p)).filter(Boolean);
      inner=`<div class="batch-cell-count">${placements.length}</div>
        <div class="batch-cell-label">${placements.length===1?'task':'tasks'} planned</div>
        <div class="batch-cell-task-preview">${previewSteps.map(s=>esc(s.text)).join(' · ')}</div>`;
    }else{
      inner=`<div class="batch-cell-empty">click to plan ahead</div>`;
    }
    html+=`<div class="batch-cell${has?' has-tasks':''}${isToday?' today':''}" onclick="openBatchPopup(${d})" ondragover="event.preventDefault();this.classList.add('drop-target')" ondragleave="this.classList.remove('drop-target')" ondrop="handleBatchDrop(event,${d})">${inner}</div>`;
  }
  row.innerHTML=html;
}

function resolveStep(pid){
  // pid format: recipeId@stepIdx@w|d|m
  const m=pid.match(/^(.+)@(\d+)@(-?\d+)\|(\d+)\|([a-z]+)$/);
  if(!m)return null;
  const [,rid,si,w,d,meal]=m;
  const r=S.recipes.find(x=>x.id===rid);
  if(!r)return null;
  const step=r.steps?.[Number(si)];
  if(!step)return null;
  const text=typeof step==='string'?step:step.text;
  return{text,recipe:r.name,recipeId:rid,stepIdx:Number(si),srcW:Number(w),srcD:Number(d),srcM:meal};
}

