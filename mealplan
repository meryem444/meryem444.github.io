<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Family Meal Plan — Meryem, Austin &amp; Arya</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#faf6ee;            /* cream */
  --bg-2:#f3ecdd;          /* deeper cream */
  --card:#fffdf9;          /* white-cream */
  --primary:#7a8a6e;       /* sage */
  --primary-dark:#5a6b50;
  --primary-light:#a8b89c;
  --accent:#c89274;        /* terracotta */
  --accent-soft:#e8c5ae;
  --rose:#d4a39c;
  --leaf:#8fa97d;
  --berry:#a76b80;
  --carrot:#d99860;
  --muted:#9b9486;
  --border:#e8dfcc;
  --text:#3a382f;
  --text-light:#6e6a5d;
  --danger:#b95440;
  --meryem:#8a6aa4;        /* plum */
  --austin:#5a8fa8;        /* ocean */
  --arya:#d99458;          /* amber */
  --radius:14px;
  --radius-sm:10px;
  --shadow:0 2px 14px rgba(80,70,40,.07);
  --shadow-lg:0 8px 36px rgba(80,70,40,.13);
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{background:var(--bg);color:var(--text);min-height:100vh}
body{
  font-family:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;
  font-size:14px;
  background-image:
    radial-gradient(circle at 8% 12%, rgba(168,184,156,.16) 0, transparent 22%),
    radial-gradient(circle at 92% 8%, rgba(212,163,156,.13) 0, transparent 24%),
    radial-gradient(circle at 6% 92%, rgba(217,148,88,.11) 0, transparent 26%),
    radial-gradient(circle at 95% 95%, rgba(143,169,125,.13) 0, transparent 24%);
  background-attachment:fixed;
}
.serif{font-family:'Cormorant Garamond',Georgia,serif;letter-spacing:.01em}
/* Botanical decorations */
.deco{position:fixed;pointer-events:none;z-index:0;opacity:.55}
.deco.tl{top:60px;left:-10px;width:170px}
.deco.tr{top:80px;right:-20px;width:200px}
.deco.bl{bottom:-30px;left:-20px;width:180px}
.deco.br{bottom:-10px;right:-30px;width:200px}
@media(max-width:780px){.deco{opacity:.3}.deco.tl,.deco.bl{width:110px}.deco.tr,.deco.br{width:130px}}

/* HEADER */
#app-header{
  background:linear-gradient(180deg,#fffdf9 0%,#f8f1e3 100%);
  border-bottom:1px solid var(--border);
  padding:14px 22px;
  display:flex;align-items:center;gap:18px;flex-wrap:wrap;
  position:sticky;top:0;z-index:100;
  box-shadow:0 1px 6px rgba(80,70,40,.04);
}
#app-header h1{
  font-family:'Cormorant Garamond',serif;
  font-size:1.55rem;font-weight:600;color:var(--primary-dark);
  letter-spacing:.02em;white-space:nowrap;
}
#nav{display:flex;gap:4px;flex-wrap:wrap}
.nav-btn{
  background:transparent;color:var(--text-light);border:none;
  padding:7px 16px;border-radius:22px;cursor:pointer;
  font-size:.83rem;font-weight:500;font-family:inherit;
  transition:all .2s;letter-spacing:.01em;
}
.nav-btn:hover{background:var(--bg-2);color:var(--text)}
.nav-btn.active{background:var(--primary);color:#fff;box-shadow:0 2px 8px rgba(122,138,110,.3)}
.week-nav{display:flex;align-items:center;gap:10px;margin-left:auto}
.week-nav button{
  background:var(--bg-2);color:var(--text);border:none;
  width:30px;height:30px;border-radius:50%;cursor:pointer;
  font-size:.85rem;font-family:inherit;display:flex;align-items:center;justify-content:center;
  transition:all .15s;
}
.week-nav button:hover{background:var(--primary);color:#fff}
.sync-nav{display:flex;gap:6px;align-items:center}
.sync-btn,.settings-btn{
  background:transparent;border:1px solid var(--border);
  color:var(--primary-dark);font-family:inherit;font-size:.78rem;font-weight:600;
  padding:6px 12px;border-radius:14px;cursor:pointer;transition:all .15s;
}
.sync-btn:hover,.settings-btn:hover{background:var(--leaf);color:#fff;border-color:var(--leaf)}
.sync-btn.syncing{background:var(--accent-soft);color:#fff;border-color:var(--accent);pointer-events:none}
.sync-btn.syncing::before{content:'';display:inline-block;width:10px;height:10px;border:2px solid #fff;border-top-color:transparent;border-radius:50%;animation:spin .7s linear infinite;margin-right:6px;vertical-align:-2px}
@keyframes spin{to{transform:rotate(360deg)}}
.settings-btn{padding:6px 10px;font-size:1rem}

#sync-settings-overlay{
  position:fixed;inset:0;background:rgba(40,32,18,.55);z-index:500;
  display:none;align-items:center;justify-content:center;padding:20px;
  backdrop-filter:blur(3px);
}
#sync-settings-overlay.open{display:flex}
.sync-settings-box{
  width:100%;max-width:520px;background:var(--card);
  border-radius:var(--radius);padding:20px 24px;box-shadow:var(--shadow-lg);
}
.sync-settings-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.sync-settings-header h2{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:600;color:var(--primary-dark)}
.sync-settings-desc{font-size:.78rem;color:var(--muted);margin-bottom:14px;line-height:1.5}
.sync-test-result{margin-top:8px;font-size:.8rem;min-height:18px}
.sync-test-result.ok{color:var(--leaf)}
.sync-test-result.err{color:var(--danger)}

#week-label{
  font-family:'Cormorant Garamond',serif;
  color:var(--accent);font-size:1.05rem;font-weight:600;
  white-space:nowrap;letter-spacing:.02em;
  padding:2px 10px;border-radius:6px;
  border:1px dashed var(--accent-soft);
  transition:background .15s,color .15s,border-color .15s;
}
#week-label:hover{background:var(--accent-soft);color:#fff;border-color:var(--accent)}
#week-label.current-week{
  color:var(--primary-dark);font-weight:500;
  border-color:transparent;
}
#week-label.current-week:hover{background:var(--sage-soft);color:var(--primary-dark)}

.page{display:none;padding:20px 22px 60px;position:relative;z-index:1}
.page.active{display:block}
.page-section-title{
  font-family:'Cormorant Garamond',serif;
  font-size:1.4rem;font-weight:600;color:var(--primary-dark);
  margin-bottom:14px;letter-spacing:.02em;
}
.page-section-sub{font-size:.78rem;color:var(--muted);margin-bottom:16px;font-style:italic}

/* PLAN PAGE */
.plan-container{max-width:1500px;margin:0 auto}
.plan-grid-wrap{overflow-x:auto;margin-bottom:24px}
.plan-grid{
  display:grid;
  grid-template-columns:120px repeat(7,minmax(140px,1fr));
  gap:8px;
  min-width:1080px;
}
.col-header{
  text-align:center;padding:10px 4px 8px;
  font-family:'Cormorant Garamond',serif;
  font-size:.85rem;font-weight:600;color:var(--primary-dark);
  text-transform:uppercase;letter-spacing:.12em;cursor:pointer;
  border-radius:8px;transition:background .15s;
}
.col-header:hover{background:var(--bg-2)}
.col-header.today{color:var(--accent)}
.col-header.focused{background:var(--primary);color:#fff}
.col-header.focused.today{background:var(--accent)}
.col-header .day-num{
  font-family:'Cormorant Garamond',serif;
  font-size:1.6rem;font-weight:600;display:block;margin-top:1px;letter-spacing:0;
}
.row-label{
  display:flex;align-items:center;justify-content:flex-end;
  padding-right:14px;
  font-family:'Cormorant Garamond',serif;
  font-size:.95rem;font-weight:600;color:var(--primary-dark);
  text-transform:uppercase;letter-spacing:.18em;
}
/* EQUAL-SIZE MEAL CELLS */
.meal-cell{
  background:var(--card);border-radius:var(--radius-sm);
  border:1.5px solid var(--border);
  height:160px; /* fixed — fits up to 6 recipes evenly */
  cursor:pointer;transition:all .18s;
  overflow:hidden;position:relative;display:flex;flex-direction:column;
}
.meal-cell:hover{border-color:var(--primary-light);box-shadow:var(--shadow);transform:translateY(-1px)}
.meal-cell.today{border-color:var(--accent-soft);background:#fffaf2}
.meal-cell.has-recipes{border-color:var(--primary-light)}
.cell-photos{display:grid;gap:2px;flex:1;min-height:0}
.cell-photos.count-1{grid-template-columns:1fr}
.cell-photos.count-2{grid-template-columns:1fr 1fr}
.cell-photos.count-3{grid-template-columns:repeat(3,1fr)}
.cell-photos.count-4{grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr}
.cell-photos.count-5,.cell-photos.count-6{grid-template-columns:repeat(3,1fr);grid-template-rows:repeat(2,1fr)}
.cell-photo-item{background:var(--bg-2);display:flex;align-items:center;justify-content:center;overflow:hidden;min-height:0}
.cell-photo-item img{width:100%;height:100%;object-fit:cover;display:block}
.recipe-name-small{
  font-family:'Cormorant Garamond',serif;
  font-size:.78rem;text-align:center;padding:4px 6px;
  color:var(--text);line-height:1.2;word-break:break-word;font-weight:500;
}
.cell-empty-hint{
  display:flex;align-items:center;justify-content:center;height:100%;
  color:var(--border);font-size:1.6rem;font-weight:300;flex:1;
}
.cell-person-dots{
  display:flex;gap:4px;padding:5px 7px;background:rgba(255,253,249,.94);
  border-top:1px solid var(--border);
}
.dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.dot.meryem{background:var(--meryem)}
.dot.austin{background:var(--austin)}
.dot.arya{background:var(--arya)}

/* BATCH ROW (smaller, distinct) */
.batch-row-wrap{
  margin-top:14px;
  display:grid;
  grid-template-columns:120px repeat(7,minmax(140px,1fr));
  gap:8px;
  min-width:1080px;
}
.batch-row-label{
  display:flex;align-items:center;justify-content:flex-end;
  padding-right:14px;
  font-family:'Cormorant Garamond',serif;
  font-size:.95rem;font-weight:600;color:var(--leaf);
  text-transform:uppercase;letter-spacing:.18em;line-height:1.1;
}
.batch-cell{
  background:#f5f8f0;border:1.5px dashed var(--leaf);
  border-radius:var(--radius-sm);
  height:88px;
  cursor:pointer;transition:all .18s;
  overflow:hidden;position:relative;display:flex;flex-direction:column;
  padding:8px 10px;
}
.batch-cell:hover{background:#eef3e3;border-style:solid;box-shadow:var(--shadow)}
.batch-cell.has-tasks{background:#eaf1de;border-style:solid}
.batch-cell-count{
  font-family:'Cormorant Garamond',serif;
  font-size:1.5rem;font-weight:600;color:var(--leaf);line-height:1;
}
.batch-cell-label{
  font-size:.66rem;color:var(--text-light);text-transform:uppercase;
  letter-spacing:.08em;margin-top:2px;
}
.batch-cell-empty{
  font-size:.7rem;color:var(--muted);font-style:italic;
  display:flex;align-items:center;justify-content:center;height:100%;text-align:center;
}
.batch-cell-task-preview{
  font-size:.7rem;color:var(--text-light);line-height:1.3;
  margin-top:3px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;
  overflow:hidden;
}

/* WEEKLY SNACKS */
.weekly-snacks-card{
  background:var(--card);
  border:1.5px solid var(--border);
  border-radius:var(--radius);
  padding:18px 22px;
  margin-top:24px;
  position:relative;overflow:hidden;
  box-shadow:var(--shadow);
}
.weekly-snacks-card::before{
  content:'';position:absolute;top:-30px;right:-30px;width:120px;height:120px;
  background:radial-gradient(circle,rgba(217,148,88,.12) 0,transparent 70%);
  pointer-events:none;
}
.ws-header{display:flex;align-items:center;gap:14px;margin-bottom:12px;flex-wrap:wrap}
.ws-title{
  font-family:'Cormorant Garamond',serif;
  font-size:1.25rem;font-weight:600;color:var(--primary-dark);
  letter-spacing:.02em;flex:1;
}
.ws-sub{font-size:.78rem;color:var(--muted);font-style:italic}
/* Snacks row in the meal grid — same height as meal cells so the grid stays even */
.snacks-row-cell{height:160px}
.snacks-strip{
  display:flex;align-items:center;gap:10px;padding:14px 16px;height:100%;flex:1;
  overflow-x:auto;
}
.snacks-strip::-webkit-scrollbar{height:5px}
.snacks-strip::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
.snack-thumb{
  flex:0 0 110px;height:124px;border-radius:10px;overflow:hidden;
  background:var(--bg-2);border:1px solid var(--border);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  transition:transform .15s,box-shadow .15s;
}
.snack-thumb:hover{transform:translateY(-2px);box-shadow:0 3px 8px rgba(80,70,40,.18)}
.snack-thumb img{width:100%;height:100%;object-fit:cover;display:block}
.snack-thumb-name{
  font-family:'Cormorant Garamond',serif;font-size:.7rem;color:var(--primary-dark);
  text-align:center;padding:6px;line-height:1.2;
}
.ws-people{display:flex;flex-direction:column;gap:10px}
.ws-person-row{
  display:flex;align-items:center;gap:10px;flex-wrap:wrap;
  padding:8px 12px;border-radius:var(--radius-sm);
}
.ws-person-row.meryem{background:rgba(138,106,164,.08)}
.ws-person-row.austin{background:rgba(90,143,168,.08)}
.ws-person-row.arya{background:rgba(217,148,88,.08)}
.ws-person-name{font-weight:600;font-size:.85rem;min-width:80px}
.ws-person-name.meryem{color:var(--meryem)}
.ws-person-name.austin{color:var(--austin)}
.ws-person-name.arya{color:var(--arya)}

/* DAILY RUN INLINE PANEL — sits inside .plan-grid-wrap so it scrolls with the grid
   and aligns horizontally with the meal cells (after the 120px label column + 8px gap). */
.daily-run-card{
  background:var(--card);border:1.5px solid var(--border);
  border-radius:var(--radius);
  padding:18px 22px;
  margin:24px 0 0 128px; /* 120px label col + 8px grid gap */
  min-width:calc(1080px - 128px); /* track plan-grid's min-width so it scrolls together */
  position:relative;overflow:hidden;
  box-shadow:var(--shadow);
}
.dr-header{display:flex;align-items:center;gap:14px;margin-bottom:14px;flex-wrap:wrap}
.dr-title{
  font-family:'Cormorant Garamond',serif;
  font-size:1.25rem;font-weight:600;color:var(--primary-dark);
  letter-spacing:.02em;flex:1;
}
.dr-day-pills{display:flex;gap:5px;flex-wrap:wrap}
.dr-day-pill{
  padding:5px 12px;border-radius:18px;border:1.5px solid var(--border);
  background:var(--card);cursor:pointer;font-size:.75rem;font-weight:600;
  color:var(--text-light);transition:all .15s;font-family:inherit;letter-spacing:.04em;
}
.dr-day-pill:hover{border-color:var(--primary);color:var(--primary)}
.dr-day-pill.active{background:var(--primary);color:#fff;border-color:var(--primary)}
.dr-day-pill.today{border-color:var(--accent)}
.dr-day-pill.active.today{background:var(--accent);border-color:var(--accent)}
.dr-tasks{display:flex;flex-direction:column;gap:6px}
.dr-task{
  display:flex;align-items:flex-start;gap:10px;
  padding:9px 12px 9px 14px;background:var(--bg);border-radius:var(--radius-sm);
  border-left:4px solid transparent;
}
.dr-task input{width:18px;height:18px;border-radius:4px;cursor:pointer;flex-shrink:0;margin-top:2px;accent-color:var(--primary)}
.dr-task-text{font-size:.85rem;flex:1;line-height:1.4}
.dr-task-text.done{text-decoration:line-through;color:var(--muted)}
.dr-task-source{font-size:.68rem;color:var(--text-light);background:var(--card);
  border:1px solid var(--border);padding:2px 8px;border-radius:8px;
  flex-shrink:0;white-space:nowrap;margin-top:2px;}
.dr-task-source.batched{border-color:var(--leaf);color:var(--leaf);background:#f5f8f0}

/* Meal pill on each daily-run task */
.dr-task-meal{
  font-size:.65rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase;
  padding:3px 8px;border-radius:6px;flex-shrink:0;margin-top:1px;
  white-space:nowrap;
}
.dr-task-carry{
  background:#fff0d8;color:#a35820;border:1px solid #e8b878;
  font-size:.62rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;
  padding:3px 8px;border-radius:6px;flex-shrink:0;margin-top:1px;white-space:nowrap;
}
.dr-task-batch{
  background:#eaf3de;color:#3b6d11;border:1px solid #c0dd97;
  font-size:.62rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;
  padding:3px 8px;border-radius:6px;flex-shrink:0;margin-top:1px;white-space:nowrap;
}
.dr-task.carry{background:linear-gradient(90deg,#fff7ec 0%,var(--bg) 70%)}
.dr-task.batch-ahead{background:linear-gradient(90deg,#f3f8e9 0%,var(--bg) 70%)}

/* Plan-ahead panel: batchable upcoming steps + custom task form */
.dr-plan-panel{
  margin-top:14px;padding:12px 14px;background:#faf6ed;border:1px dashed var(--border);
  border-radius:var(--radius-sm);
}
.dr-plan-header{display:flex;align-items:baseline;gap:10px;margin-bottom:10px;flex-wrap:wrap}
.dr-plan-title{font-family:'Cormorant Garamond',serif;font-size:1rem;font-weight:600;color:var(--primary-dark)}
.dr-plan-sub{font-size:.72rem;color:var(--muted);font-style:italic}
.ca-candidate{
  display:flex;flex-direction:column;gap:4px;
  background:#fff;border:1px solid var(--border);border-radius:var(--radius-sm);
  padding:8px 10px;margin-bottom:6px;cursor:grab;transition:all .12s;
}
.ca-candidate:hover{border-color:var(--leaf);background:#fafdf6}
.ca-candidate:active{cursor:grabbing}
.ca-cand-text{font-size:.84rem;color:var(--text);line-height:1.3}
.ca-cand-meta{display:flex;align-items:center;gap:8px;flex-wrap:wrap;font-size:.7rem;color:var(--muted)}
.ca-recipe{font-weight:600;color:var(--primary-dark)}
.ca-for{font-style:italic}
.ca-cand-add{
  margin-left:auto;background:var(--leaf);color:#fff;border:none;
  font-family:inherit;font-size:.7rem;font-weight:600;padding:4px 10px;
  border-radius:10px;cursor:pointer;transition:all .12s;
}
.ca-cand-add:hover{background:var(--primary-dark)}
.ca-empty{color:var(--muted);font-style:italic;font-size:.78rem;padding:6px 0}
.dr-day-pill.drop-target{outline:2px dashed var(--leaf);outline-offset:2px;background:#f3f8e9}

/* Custom task inline form */
.dr-custom-form{
  display:flex;gap:6px;margin-top:10px;align-items:center;
}
.dr-custom-input{
  flex:1;height:34px;padding:0 12px;font-size:.85rem;font-family:inherit;
  border:1px solid var(--border);border-radius:18px;background:#fff;color:var(--text);
  outline:none;transition:border-color .15s;
}
.dr-custom-input:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(200,146,116,.18)}
.dr-custom-btn{
  background:transparent;border:1.5px dashed var(--border);
  color:var(--primary);font-size:.78rem;font-weight:600;cursor:pointer;
  padding:6px 14px;border-radius:18px;font-family:inherit;transition:all .15s;
}
.dr-custom-btn:hover{border-color:var(--primary);color:var(--primary-dark);background:var(--bg-2)}
.dr-task-meal.meal-breakfast{background:#fdf0e0;color:#a86730;border:1px solid #f0d9b8}
.dr-task-meal.meal-lunch{background:#eff5e8;color:#5a7d3e;border:1px solid #d4e3c0}
.dr-task-meal.meal-dinner{background:#f5e3e9;color:#8b3f5a;border:1px solid #e6c5d0}
.dr-task-meal.meal-custom{background:#f0ece4;color:#7a7464;border:1px solid #ddd5c4}

/* Soft left-edge tint per meal */
.dr-task.meal-breakfast-bar{border-left-color:var(--carrot)}
.dr-task.meal-lunch-bar{border-left-color:var(--leaf)}
.dr-task.meal-dinner-bar{border-left-color:var(--berry)}
.dr-task.meal-custom-bar{border-left-color:var(--muted)}
.dr-empty{color:var(--muted);font-size:.85rem;padding:14px 0;font-style:italic;text-align:center}
.dr-add-btn{
  background:transparent;border:1.5px dashed var(--border);
  color:var(--primary);font-size:.78rem;font-weight:600;cursor:pointer;
  padding:7px 14px;border-radius:18px;margin-top:6px;align-self:flex-start;
  font-family:inherit;transition:all .15s;
}
.dr-add-btn:hover{border-color:var(--primary);background:var(--bg-2)}

/* OVERLAY / POPUP */
.overlay{
  position:fixed;inset:0;background:rgba(60,55,40,.42);z-index:200;
  display:none;align-items:center;justify-content:center;padding:16px;
  backdrop-filter:blur(2px);
}
.overlay.open{display:flex}
.popup-box{
  background:var(--card);border-radius:var(--radius);
  width:100%;max-width:600px;max-height:90vh;overflow-y:auto;
  box-shadow:var(--shadow-lg);display:flex;flex-direction:column;
  border:1px solid var(--border);
}
.popup-header{
  padding:18px 22px 14px;border-bottom:1px solid var(--border);
  display:flex;align-items:flex-start;justify-content:space-between;
  position:sticky;top:0;background:var(--card);z-index:1;
}
.popup-title{
  font-family:'Cormorant Garamond',serif;
  font-size:1.3rem;font-weight:600;color:var(--primary-dark);
  letter-spacing:.02em;
}
.popup-subtitle{font-size:.8rem;color:var(--muted);margin-top:3px}
.popup-close{
  background:none;border:none;font-size:1.3rem;cursor:pointer;color:var(--muted);
  width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;
  flex-shrink:0;transition:background .15s;
}
.popup-close:hover{background:var(--bg);color:var(--text)}
.popup-body{padding:18px 22px;flex:1}
.person-section{margin-bottom:14px;padding-bottom:14px;border-bottom:1px solid var(--bg-2)}
.person-section:last-of-type{border-bottom:none}
.person-header{display:flex;align-items:center;gap:8px;padding:8px 14px;border-radius:var(--radius-sm);margin-bottom:8px}
.person-header.meryem{background:rgba(138,106,164,.1)}
.person-header.austin{background:rgba(90,143,168,.1)}
.person-header.arya{background:rgba(217,148,88,.1)}
.person-label{font-size:.9rem;font-weight:700;flex:1;letter-spacing:.02em}
.person-label.meryem{color:var(--meryem)}
.person-label.austin{color:var(--austin)}
.person-label.arya{color:var(--arya)}
.person-log-btn{
  font-size:.7rem;padding:4px 10px;border-radius:18px;border:1.5px solid;
  background:transparent;cursor:pointer;font-weight:600;transition:all .15s;font-family:inherit;
}
.person-log-btn.meryem{border-color:var(--meryem);color:var(--meryem)}
.person-log-btn.austin{border-color:var(--austin);color:var(--austin)}
.person-log-btn.arya{border-color:var(--arya);color:var(--arya)}
.person-log-btn.logged{color:#fff!important}
.person-log-btn.meryem.logged{background:var(--meryem)}
.person-log-btn.austin.logged{background:var(--austin)}
.person-log-btn.arya.logged{background:var(--arya)}
.recipe-chips{display:flex;flex-wrap:wrap;gap:6px;min-height:32px;align-items:center}
.recipe-chip{
  display:inline-flex;align-items:center;gap:6px;background:var(--bg);
  border:1.5px solid var(--border);border-radius:18px;padding:5px 11px;
  font-size:.78rem;font-weight:500;color:var(--text);
}
.recipe-chip img{width:22px;height:22px;border-radius:50%;object-fit:cover}
.chip-thumb-mini{
  width:22px;height:22px;border-radius:50%;
  background:linear-gradient(135deg,var(--primary-light),var(--accent-soft));
  flex-shrink:0;
}
.chip-remove{background:none;border:none;cursor:pointer;color:var(--muted);font-size:.85rem;padding:0 0 0 3px;transition:color .15s}
.chip-remove:hover{color:var(--danger)}
.add-recipe-btn{
  background:none;border:1.5px dashed var(--border);border-radius:18px;
  padding:5px 12px;font-size:.78rem;color:var(--muted);cursor:pointer;transition:all .15s;font-family:inherit;
}
.add-recipe-btn:hover{border-color:var(--primary);color:var(--primary);background:var(--bg-2)}
.slot-info{font-size:.74rem;color:var(--muted);padding:10px 22px 16px;border-top:1px solid var(--bg-2);font-style:italic}

/* RECIPE BOOK SIDE PANEL (Notion-style peek from right) */
#book-overlay{
  position:fixed;top:0;right:0;bottom:0;width:1200px;max-width:98vw;
  z-index:400;background:transparent;
  transform:translateX(100%);pointer-events:none;
  transition:transform .42s cubic-bezier(.4,.05,.3,1);
}
#book-overlay.open{transform:translateX(0);pointer-events:auto}
.book-container{
  width:100%;height:100%;display:flex;flex-direction:column;
  background:#fdfaf2;border-left:1px solid var(--border);
  box-shadow:-12px 0 36px rgba(40,30,15,.18),-2px 0 8px rgba(40,30,15,.08);
  position:relative;
}
.book-toolbar{
  display:flex;align-items:center;gap:10px;padding:14px 18px 10px;position:relative;
}
#book-search{
  flex:1;height:36px;padding:0 14px;font-size:.92rem;font-family:inherit;
  border:1px solid var(--border);border-radius:18px;background:#fff;color:var(--text);
  outline:none;transition:border-color .15s;
}
#book-search:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(200,146,116,.18)}
.book-filter-btn{
  border:1px solid var(--border);background:#fff;color:var(--primary-dark);
  font-family:inherit;font-size:.78rem;font-weight:600;cursor:pointer;
  padding:7px 12px;border-radius:14px;white-space:nowrap;transition:all .15s;
}
.book-filter-btn:hover{background:var(--primary);color:#fff;border-color:var(--primary)}
.book-target{
  font-family:'Cormorant Garamond',serif;font-size:.85rem;color:var(--accent);
  font-weight:600;font-style:italic;white-space:nowrap;
  background:rgba(200,146,116,.1);padding:4px 10px;border-radius:10px;
  max-width:170px;overflow:hidden;text-overflow:ellipsis;
}
.book-close{
  background:transparent;border:none;font-size:1.6rem;color:var(--muted);cursor:pointer;
  width:32px;height:32px;line-height:1;border-radius:50%;transition:all .15s;
}
.book-close:hover{background:var(--bg-2);color:var(--text)}
#book-filter-menu{
  display:none;position:absolute;top:54px;right:18px;width:300px;max-height:60vh;overflow-y:auto;
  background:#fff;border:1px solid var(--border);border-radius:12px;
  box-shadow:0 12px 32px rgba(40,30,15,.18);padding:10px 12px;z-index:10;
}
#book-filter-menu.open{display:block}
.bfm-section{padding:6px 0;border-bottom:1px solid var(--bg-2)}
.bfm-section:last-child{border-bottom:none}
.bfm-label{font-size:.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;font-weight:600;margin-bottom:6px}
.bfm-chips{display:flex;flex-wrap:wrap;gap:5px}
.bfm-chips button{
  background:var(--bg-2);border:none;color:var(--text);font-family:inherit;
  font-size:.74rem;padding:4px 10px;border-radius:10px;cursor:pointer;transition:all .12s;
}
.bfm-chips button:hover{background:var(--accent-soft);color:#fff}
.book-active-filters{
  display:flex;flex-wrap:wrap;gap:6px;padding:0 18px 8px;min-height:0;
}
.book-active-filters:empty{display:none}
.book-active-filters .active-chip{
  background:var(--accent-soft);color:#5a3a2a;font-size:.74rem;padding:4px 6px 4px 10px;
  border-radius:10px;display:inline-flex;align-items:center;gap:4px;font-weight:500;
}
.book-active-filters .active-chip button{
  background:transparent;border:none;color:#5a3a2a;cursor:pointer;font-size:.95rem;
  width:18px;height:18px;border-radius:50%;line-height:1;padding:0;
}
.book-active-filters .active-chip button:hover{background:rgba(255,255,255,.4)}

.book-spread-wrap{
  flex:1;display:grid;grid-template-columns:36px 1fr 36px;gap:6px;align-items:stretch;
  padding:4px 12px 16px;min-height:0;
}
.book-arrow{
  display:flex;align-items:center;justify-content:center;
  background:transparent;border:none;color:var(--muted);font-size:2rem;cursor:pointer;
  border-radius:8px;transition:all .15s;font-family:inherit;
}
.book-arrow:hover{background:var(--bg-2);color:var(--accent)}
.book-arrow:disabled{opacity:.25;cursor:default}
.book-arrow:disabled:hover{background:transparent;color:var(--muted)}

.book-spread{
  position:relative;display:grid;grid-template-columns:1fr 6px 1fr;gap:0;
  background:#f3ebd9;border-radius:6px;padding:14px;
  perspective:2400px;min-height:420px;
}
.book-page{
  background:#fffdf6;border:1px solid #e8dfcc;border-radius:4px;
  padding:14px 16px;overflow-y:auto;
  box-shadow:inset 0 0 8px rgba(120,100,60,.05);
  font-size:.85rem;color:var(--text);
  display:flex;flex-direction:column;
}
.book-page.left{box-shadow:inset -6px 0 12px -6px rgba(120,100,60,.18)}
.book-page.right{box-shadow:inset 6px 0 12px -6px rgba(120,100,60,.18)}
.book-spine{
  background:linear-gradient(90deg,rgba(120,100,60,.18),rgba(120,100,60,.28),rgba(120,100,60,.18));
  border-radius:1px;
}
.book-page.empty{display:flex;align-items:center;justify-content:center;color:var(--muted);font-style:italic;font-size:.78rem}

/* The page recipe content (1 recipe spans 2 pages) */
.bp-photo{
  width:100%;height:200px;background:linear-gradient(135deg,var(--accent-soft),var(--rose));
  border-radius:4px;margin-bottom:12px;display:flex;align-items:center;justify-content:center;
  color:#5a3a2a;font-size:.78rem;font-style:italic;background-size:cover;background-position:center;
}
.bp-title{font-family:'Cormorant Garamond',serif;font-size:1.45rem;font-weight:600;color:var(--primary-dark);margin-bottom:4px;line-height:1.15}
.bp-meta{font-size:.74rem;color:var(--muted);margin-bottom:10px}
.bp-section-label{font-size:.7rem;color:var(--accent);font-weight:600;letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px}
.bp-ingredients-list{list-style:none;padding:0;margin:0 0 10px;font-size:.82rem;color:var(--text);line-height:1.7}
.bp-ingredients-list li{padding:3px 0;border-bottom:1px dotted var(--bg-2)}
.bp-ingredients-list li:last-child{border-bottom:none}
.bp-ing-amt{color:var(--accent);font-weight:600;display:inline-block;min-width:50px}
.bp-steps-list{list-style:none;padding:0;margin:0;font-size:.84rem;color:var(--text);line-height:1.55;counter-reset:step}
.bp-steps-list li{counter-increment:step;padding:7px 0 7px 30px;position:relative;border-bottom:1px dotted var(--bg-2)}
.bp-steps-list li:last-child{border-bottom:none}
.bp-steps-list li::before{
  content:counter(step);position:absolute;left:0;top:7px;
  font-family:'Cormorant Garamond',serif;font-size:1.1rem;color:var(--accent);font-weight:600;
}
.bp-steps-list li.batch::after{
  content:'batch';position:absolute;right:0;top:9px;font-size:.6rem;
  background:#f5f8f0;color:var(--leaf);padding:2px 8px;border-radius:8px;border:1px solid var(--leaf);font-weight:600;
}
.bp-warnings{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:10px}
.bp-warn{background:#fdf0e0;color:#a86730;font-size:.68rem;padding:3px 8px;border-radius:8px;border:1px solid #f0d9b8;font-weight:500}
.bp-tags{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:10px}
.bp-tag{background:var(--bg-2);color:var(--text-light);font-size:.68rem;padding:3px 8px;border-radius:8px}
.bp-tag.bp-tag-paleo{background:#eaf3de;color:#3b6d11;border:1px solid #c0dd97}
.bp-tag.bp-tag-keto{background:#f5e3e9;color:#8b3f5a;border:1px solid #e6c5d0}
.bp-notes{font-size:.74rem;color:var(--text-light);font-style:italic;line-height:1.5;padding-top:8px;border-top:1px solid var(--bg-2)}
.bp-nutri{width:100%;border-collapse:collapse;font-size:.78rem;margin-top:4px}
.bp-nutri th{text-align:right;font-weight:600;color:var(--muted);font-size:.7rem;text-transform:uppercase;letter-spacing:.04em;padding:4px 6px;border-bottom:1px solid var(--bg-2)}
.bp-nutri th:first-child{text-align:left}
.bp-nutri td{padding:4px 6px;color:var(--text);text-align:right;font-variant-numeric:tabular-nums}
.bp-nutri td:first-child{text-align:left;color:var(--text-light)}
.bp-nutri tbody tr:nth-child(even){background:var(--bg-2)}
.bp-compound-chips{display:flex;flex-wrap:wrap;gap:4px;margin:6px 0 8px}
.bp-compound{background:#f3f0e6;color:#6b5a30;font-size:.66rem;padding:2px 8px;border-radius:8px;border:1px solid #d9cfb1;font-weight:500}
.bp-healing-list{list-style:none;padding:0;margin:0;font-size:.78rem;color:var(--text);line-height:1.5}
.bp-healing-list li{padding:5px 0;border-bottom:1px dotted var(--bg-2)}
.bp-healing-list li:last-child{border-bottom:none}
.bp-healing-list strong{color:var(--accent);font-weight:600}
.bp-footer{display:flex;justify-content:space-between;align-items:center;padding-top:10px;border-top:1px solid var(--bg-2);margin-top:auto}
.bp-stats{font-size:.7rem;color:var(--muted)}
.bp-add{background:var(--accent);color:#fff;border:none;font-family:inherit;font-size:.78rem;font-weight:600;padding:6px 14px;border-radius:14px;cursor:pointer;transition:all .15s}
.bp-add:hover{background:var(--primary);transform:translateY(-1px)}

/* TABLE OF CONTENTS (first spread of the book) */
.toc-page{font-family:'Cormorant Garamond',serif;color:var(--text);padding:8px 6px}
.toc-title{
  font-family:'Cormorant Garamond',serif;font-size:2rem;font-style:italic;font-weight:500;
  color:var(--primary-dark);margin-bottom:18px;line-height:1;
}
.toc-part-heading{
  font-family:'Cormorant Garamond',serif;
  font-size:1.05rem;font-weight:600;letter-spacing:.32em;
  color:var(--primary-dark);
  text-transform:uppercase;
  text-align:center;
  margin:18px 0 12px;
  padding-bottom:8px;
  border-bottom:1.5px solid var(--border);
  position:relative;
}
.toc-part-heading:first-child{margin-top:4px}
.toc-section{margin-bottom:14px}
.toc-section-label{
  display:inline-block;padding:5px 12px;font-family:'Inter',sans-serif;
  font-weight:700;font-size:.7rem;letter-spacing:.12em;color:#fff;
  text-transform:uppercase;
  border-radius:0;margin-bottom:7px;
}
/* Morning Nourishment */
.toc-section-label.sec-breakfast-bowls{background:var(--carrot)}
.toc-section-label.sec-eggs{background:#d6a352}
.toc-section-label.sec-smoothies-bf{background:var(--rose)}
.toc-section-label.sec-muffins{background:#a87454}
/* Soups, Salads & Light Meals */
.toc-section-label.sec-broths{background:#5a8fa8}
.toc-section-label.sec-salads{background:#7ea863}
.toc-section-label.sec-wraps{background:#9aa569}
/* Mains & Hearty Dishes */
.toc-section-label.sec-onepan{background:var(--accent)}
.toc-section-label.sec-stews{background:#456b87}
.toc-section-label.sec-pasta{background:#c4994a}
.toc-section-label.sec-casseroles{background:var(--berry)}
/* Snacks & Drinks */
.toc-section-label.sec-dips{background:var(--leaf)}
.toc-section-label.sec-teas{background:#7ba38c}
.toc-section-label.sec-smoothies-sj{background:#c47a96}
/* Sweets & Baked Goods */
.toc-section-label.sec-cookies{background:#b8845e}
.toc-section-label.sec-desserts{background:#c4759a}
.toc-section-label.sec-breads{background:#9c6b4d}
/* Nature's Apothecary */
.toc-section-label.sec-fermented{background:#b08642}
.toc-section-label.sec-infusions{background:#6f8c9b}
.toc-section-label.sec-tonics{background:#a85a4a}
.toc-section-label.sec-jams{background:#b54a5e}
/* Catch-all */
.toc-section-label.sec-other{background:var(--muted)}
.toc-entry{
  display:flex;align-items:baseline;gap:4px;font-size:.92rem;line-height:1.55;
  padding:2px 4px;cursor:pointer;border-radius:3px;color:var(--text);
  transition:background .12s,color .12s;
}
.toc-entry:hover{background:rgba(200,146,116,.12);color:var(--accent)}
.toc-entry-name{flex-shrink:0}
.toc-entry-leader{flex:1;border-bottom:1.5px dotted var(--muted);margin:0 6px;height:.6em;opacity:.55}
.toc-entry-num{font-family:'Inter',sans-serif;font-size:.78rem;color:var(--muted);min-width:18px;text-align:right;font-variant-numeric:tabular-nums}

.toc-right-pane{padding:8px 6px}
.toc-rp-title{
  font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-style:italic;font-weight:500;
  color:var(--primary-dark);margin-bottom:14px;line-height:1;
}
.toc-rp-section{margin-bottom:18px}
.toc-rp-label{
  font-family:'Inter',sans-serif;font-size:.7rem;letter-spacing:.1em;font-weight:700;
  color:var(--muted);text-transform:uppercase;margin-bottom:8px;padding-bottom:4px;
  border-bottom:1px solid var(--bg-2);
}
.toc-rp-list{list-style:none;padding:0;margin:0}
.toc-rp-list li{
  font-size:.84rem;padding:4px 0;color:var(--text);cursor:pointer;
  display:flex;align-items:baseline;gap:6px;transition:color .12s;
}
.toc-rp-list li:hover{color:var(--accent)}
.toc-rp-list li::before{content:'·';color:var(--accent);font-weight:600}

/* Recommendations strip at bottom of book panel */
.book-recs{
  border-top:1px solid var(--border);padding:10px 16px 14px;background:#faf6ed;flex-shrink:0;
}
.book-recs-header{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:8px}
.book-recs-title{font-family:'Cormorant Garamond',serif;font-size:.95rem;font-weight:600;color:var(--primary-dark)}
.book-recs-sub{font-size:.7rem;color:var(--muted);font-style:italic}
.book-recs-strip{display:flex;gap:8px;overflow-x:auto;padding-bottom:4px}
.book-recs-strip::-webkit-scrollbar{height:6px}
.book-recs-strip::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
.rec-card{
  flex:0 0 110px;background:#fff;border:1px solid var(--border);border-radius:8px;padding:6px;
  cursor:pointer;transition:all .15s;display:flex;flex-direction:column;
}
.rec-card:hover{border-color:var(--accent);transform:translateY(-2px);box-shadow:0 3px 8px rgba(80,70,40,.1)}
.rec-photo{width:100%;height:60px;background:linear-gradient(135deg,var(--accent-soft),var(--rose));border-radius:4px;margin-bottom:5px;background-size:cover;background-position:center;display:flex;align-items:center;justify-content:center;color:#5a3a2a;font-size:.55rem;font-style:italic}
.rec-name{font-size:.7rem;color:var(--text);font-weight:500;line-height:1.25;margin-bottom:3px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.rec-tag{font-size:.58rem;color:var(--muted);text-transform:uppercase;letter-spacing:.04em;font-weight:600}
.rec-tag.protein{color:#a3402c}
.rec-tag.fish{color:#1e6d99}
.rec-tag.plant{color:#3b6d11}

/* 3D page-flip */
.book-flipper{
  position:absolute;top:14px;bottom:14px;left:50%;width:calc(50% - 17px);
  transform-origin:left center;transform-style:preserve-3d;
  pointer-events:none;display:none;
  transition:transform .65s cubic-bezier(.4,.05,.3,1);
}
.book-flipper.show{display:block}
.book-flipper.flip-fwd{transform:rotateY(-180deg)}
.book-flipper.flip-bwd{transform:rotateY(180deg);transform-origin:right center}
.bf-front,.bf-back{
  position:absolute;inset:0;background:#fffdf6;border:1px solid #e8dfcc;border-radius:4px;
  padding:14px 16px;backface-visibility:hidden;overflow:hidden;
}
.bf-back{transform:rotateY(180deg)}
.book-flipper.flip-bwd .bf-back{transform:rotateY(-180deg)}

.book-footer{
  text-align:center;font-size:.74rem;color:var(--muted);padding:0 18px 12px;font-style:italic;
}

/* RECIPE PICKER */
#recipe-picker-overlay,#batch-popup-overlay,#snacks-popup-overlay{
  position:fixed;inset:0;background:rgba(60,55,40,.5);z-index:300;
  display:none;align-items:center;justify-content:center;padding:16px;backdrop-filter:blur(3px);
}
#recipe-picker-overlay.open,#batch-popup-overlay.open,#snacks-popup-overlay.open{display:flex}
.picker-box{
  background:var(--card);border-radius:var(--radius);width:100%;max-width:520px;
  max-height:84vh;display:flex;flex-direction:column;box-shadow:var(--shadow-lg);
  border:1px solid var(--border);
}
.picker-header{
  padding:16px 18px 12px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:10px;
}
.picker-header h3{
  font-family:'Cormorant Garamond',serif;
  font-size:1.15rem;font-weight:600;color:var(--primary-dark);flex:1;letter-spacing:.02em;
}
.picker-search-wrap{padding:12px 16px;border-bottom:1px solid var(--border)}
#picker-search{
  border:1.5px solid var(--border);border-radius:18px;padding:8px 16px;
  font-size:.85rem;width:100%;outline:none;font-family:inherit;background:var(--bg);
}
#picker-search:focus{border-color:var(--primary);background:var(--card)}
.picker-list{overflow-y:auto;flex:1;padding:8px}
.picker-item{
  display:flex;align-items:center;gap:11px;padding:10px;border-radius:var(--radius-sm);
  cursor:pointer;transition:background .15s;
}
.picker-item:hover{background:var(--bg)}
.pi-thumb{
  width:42px;height:42px;border-radius:8px;
  background:linear-gradient(135deg,#e8f0d8,#f5e8d0);
  display:flex;align-items:center;justify-content:center;
  font-family:'Cormorant Garamond',serif;font-size:1rem;color:var(--primary);font-weight:600;
  flex-shrink:0;
}
.picker-item img{width:42px;height:42px;border-radius:8px;object-fit:cover;flex-shrink:0}
.pi-name{font-size:.88rem;font-weight:600}
.pi-tags{font-size:.7rem;color:var(--muted);margin-top:2px}

/* BATCH POPUP */
.batch-box{
  background:var(--card);border-radius:var(--radius);width:100%;max-width:640px;
  max-height:88vh;display:flex;flex-direction:column;box-shadow:var(--shadow-lg);
  border:1px solid var(--border);
}
.batch-section{padding:14px 20px}
.batch-section + .batch-section{border-top:1px solid var(--bg-2)}
.batch-section-title{
  font-family:'Cormorant Garamond',serif;
  font-size:1.05rem;font-weight:600;color:var(--primary-dark);
  margin-bottom:10px;letter-spacing:.02em;
}
.batch-step-row{
  display:flex;gap:11px;align-items:flex-start;
  padding:10px 12px;background:var(--bg);border-radius:var(--radius-sm);
  margin-bottom:7px;cursor:grab;border:1.5px solid transparent;
  transition:all .15s;
}
.batch-step-row:hover{background:var(--bg-2);border-color:var(--border)}
.batch-step-row.dragging{opacity:.4}
.batch-step-row.drop-target{border-color:var(--leaf);background:#eef3e3}
.batch-step-row.planned-here{background:#eaf1de;border-color:var(--leaf)}
.batch-step-check{width:18px;height:18px;cursor:pointer;flex-shrink:0;margin-top:1px;accent-color:var(--leaf)}
.batch-step-info{flex:1;min-width:0}
.batch-step-text{font-size:.85rem;line-height:1.35;color:var(--text)}
.batch-step-meta{font-size:.7rem;color:var(--text-light);margin-top:3px;display:flex;gap:8px;flex-wrap:wrap}
.batch-step-pill{
  background:var(--card);border:1px solid var(--border);
  padding:1px 7px;border-radius:8px;
}
.batch-step-pill.recipe{color:var(--primary-dark);font-weight:500}
.batch-empty{color:var(--muted);font-size:.83rem;font-style:italic;padding:6px 0}

/* RECIPE BOOK */
.recipe-book-container{max-width:1200px;margin:0 auto}
.recipe-book-toolbar{display:flex;gap:10px;align-items:center;margin-bottom:18px;flex-wrap:wrap}
#rb-search{
  border:1.5px solid var(--border);border-radius:20px;padding:9px 16px;
  font-size:.86rem;min-width:240px;outline:none;flex:1;max-width:340px;
  font-family:inherit;background:var(--card);
}
#rb-search:focus{border-color:var(--primary)}
.recipe-list{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:14px}
.recipe-card{
  background:var(--card);border-radius:var(--radius);box-shadow:var(--shadow);
  overflow:hidden;cursor:pointer;transition:all .18s;
  border:1.5px solid var(--border);
}
.recipe-card:hover{border-color:var(--primary-light);transform:translateY(-2px);box-shadow:var(--shadow-lg)}
.recipe-card-photo{width:100%;height:150px;object-fit:cover;display:block}
.recipe-card-photo-placeholder{
  width:100%;height:150px;
  background:linear-gradient(135deg,#e8f0d8,#f5e8d0);
  display:flex;align-items:center;justify-content:center;
  font-family:'Cormorant Garamond',serif;
  font-size:1.6rem;color:var(--primary-dark);font-weight:600;font-style:italic;
}
.recipe-card-body{padding:14px}
.recipe-card-name{
  font-family:'Cormorant Garamond',serif;
  font-size:1.05rem;font-weight:600;color:var(--text);margin-bottom:6px;line-height:1.2;
}
.recipe-card-meta{font-size:.74rem;color:var(--muted);display:flex;gap:10px;flex-wrap:wrap;margin-bottom:8px}
.recipe-card-tags{display:flex;flex-wrap:wrap;gap:4px}
.tag{
  font-size:.65rem;background:var(--bg-2);border:1px solid var(--border);
  border-radius:10px;padding:2px 8px;color:var(--text-light);font-weight:500;
}
.tag.breakfast{background:#fff4dc;border-color:#e8c97c;color:#7a5a00}
.tag.lunch{background:#e8f0d8;border-color:#9bb87a;color:#3a5520}
.tag.dinner{background:#ece2f0;border-color:#a888bc;color:#4a2870}
.tag.snacks{background:#fde0e0;border-color:#c87878;color:#7a2020}
.tag.batch{background:#e2efd0;border-color:#80a866;color:#1a4818}

/* RECIPE EDITOR */
#recipe-editor-overlay{
  position:fixed;inset:0;background:rgba(60,55,40,.5);z-index:300;
  display:none;align-items:flex-start;justify-content:center;
  padding:24px 16px;overflow-y:auto;backdrop-filter:blur(2px);
}
#recipe-editor-overlay.open{display:flex}
.editor-box{
  background:var(--card);border-radius:var(--radius);width:100%;max-width:680px;
  box-shadow:var(--shadow-lg);margin:auto;border:1px solid var(--border);
}
.editor-header{
  padding:18px 22px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
}
.editor-header h2{
  font-family:'Cormorant Garamond',serif;
  font-size:1.3rem;font-weight:600;color:var(--primary-dark);letter-spacing:.02em;
}
.editor-body{padding:20px 22px}
.form-group{margin-bottom:16px}
.form-label{
  font-size:.74rem;font-weight:700;color:var(--text-light);
  display:block;margin-bottom:6px;text-transform:uppercase;letter-spacing:.08em;
}
.form-input{
  width:100%;border:1.5px solid var(--border);border-radius:8px;
  padding:10px 13px;font-size:.88rem;outline:none;font-family:inherit;
  transition:border .15s;background:var(--card);color:var(--text);
}
.form-input:focus{border-color:var(--primary)}
textarea.form-input{resize:vertical;min-height:70px}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:13px}
.photo-upload-area{
  border:2px dashed var(--border);border-radius:var(--radius-sm);
  padding:24px;text-align:center;cursor:pointer;transition:all .15s;
  background:var(--bg);
}
.photo-upload-area:hover{border-color:var(--primary);background:#f6fff6}
.photo-upload-area img{max-height:160px;border-radius:8px;margin-bottom:8px}
.photo-upload-area-text{font-size:.85rem;color:var(--muted)}
.photo-upload-area-icon{
  font-family:'Cormorant Garamond',serif;font-size:1.4rem;color:var(--primary);
  margin-bottom:6px;font-weight:500;letter-spacing:.05em;
}
.tag-pills{display:flex;flex-wrap:wrap;gap:6px}

/* Ingredient row autocomplete */
.ingr-search-wrap{position:relative;flex:1;min-width:0}
.ingr-search-wrap .ingr-name{width:100%}
.ingr-suggest{
  display:none;position:absolute;top:calc(100% + 4px);left:0;right:0;
  background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm);
  box-shadow:0 8px 24px rgba(40,30,15,.12);max-height:280px;overflow-y:auto;
  z-index:50;
}
.ingr-suggest.open{display:block}
.ingr-suggest-item{
  display:flex;align-items:center;gap:8px;padding:8px 12px;cursor:pointer;
  font-size:.84rem;border-bottom:1px solid var(--bg-2);transition:background .1s;
}
.ingr-suggest-item:last-child{border-bottom:none}
.ingr-suggest-item:hover{background:var(--bg-2)}
.ingr-suggest-name{flex:1;color:var(--text);font-weight:500}
.ingr-suggest-cat{font-size:.7rem;color:var(--muted);background:var(--bg);padding:2px 6px;border-radius:6px}
.ingr-suggest-cal{font-size:.7rem;color:var(--accent);font-variant-numeric:tabular-nums}
.ingr-suggest-empty{padding:12px;color:var(--muted);font-size:.78rem;font-style:italic;line-height:1.5}
.tag-pill{
  padding:6px 13px;border-radius:18px;border:1.5px solid var(--border);
  background:var(--bg);font-size:.78rem;cursor:pointer;
  transition:all .15s;font-weight:500;font-family:inherit;
}
.tag-pill.selected{background:var(--primary);color:#fff;border-color:var(--primary)}
.steps-list{display:flex;flex-direction:column;gap:8px;margin-bottom:8px}
.step-row{
  display:grid;grid-template-columns:auto 1fr auto auto;gap:9px;align-items:flex-start;
  background:var(--bg);border-radius:var(--radius-sm);padding:10px 12px;
}
.step-num{
  font-family:'Cormorant Garamond',serif;
  font-size:.95rem;font-weight:600;color:var(--primary);padding-top:7px;min-width:18px;
}
.step-text-input{
  border:1.5px solid var(--border);border-radius:6px;padding:7px 10px;
  font-size:.85rem;font-family:inherit;resize:vertical;min-height:38px;
  outline:none;background:var(--card);color:var(--text);
}
.step-text-input:focus{border-color:var(--primary)}
.step-batch-toggle{
  display:flex;align-items:center;gap:6px;font-size:.74rem;color:var(--text-light);
  font-weight:500;cursor:pointer;padding-top:8px;white-space:nowrap;
}
.step-batch-toggle input{width:14px;height:14px;cursor:pointer;accent-color:var(--leaf)}
.step-remove{
  background:none;border:none;color:var(--muted);cursor:pointer;
  font-size:.95rem;padding:6px;border-radius:4px;
  font-family:inherit;
}
.step-remove:hover{color:var(--danger);background:#fde8e8}

.ingredients-list{display:flex;flex-direction:column;gap:6px;margin-bottom:8px}
.ingr-row{display:flex;align-items:center;gap:6px}
.ingr-name{flex:2;border:1.5px solid var(--border);border-radius:6px;padding:7px 10px;font-size:.85rem;font-family:inherit;outline:none;min-width:0;background:var(--card);color:var(--text)}
.ingr-name:focus{border-color:var(--primary)}
.ingr-amount{width:70px;border:1.5px solid var(--border);border-radius:6px;padding:7px 8px;font-size:.85rem;outline:none;font-family:inherit;background:var(--card);color:var(--text)}
.ingr-unit{width:65px;border:1.5px solid var(--border);border-radius:6px;padding:7px 8px;font-size:.85rem;outline:none;font-family:inherit;background:var(--card);color:var(--text)}
.ingr-remove{background:none;border:none;color:var(--muted);cursor:pointer;font-size:.95rem;flex-shrink:0;font-family:inherit}
.ingr-remove:hover{color:var(--danger)}
.editor-footer{
  padding:14px 22px;border-top:1px solid var(--border);
  display:flex;gap:10px;justify-content:flex-end;align-items:center;
}

/* WEEKLY RECIPES */
.weekly-recipes-container{max-width:920px;margin:0 auto}
.wr-recipe{background:var(--card);border-radius:var(--radius);box-shadow:var(--shadow);margin-bottom:11px;overflow:hidden;border:1.5px solid var(--border)}
.wr-header{padding:14px 18px;display:flex;align-items:center;gap:13px;cursor:pointer}
.wr-header:hover{background:var(--bg-2)}
.wr-photo{width:54px;height:54px;border-radius:8px;object-fit:cover;flex-shrink:0}
.wr-photo-placeholder{
  width:54px;height:54px;border-radius:8px;
  background:linear-gradient(135deg,#e8f0d8,#f5e8d0);
  display:flex;align-items:center;justify-content:center;
  font-family:'Cormorant Garamond',serif;font-size:1.3rem;color:var(--primary-dark);font-weight:600;
  flex-shrink:0;
}
.wr-info{flex:1}
.wr-name{font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:600;color:var(--text)}
.wr-meta{font-size:.75rem;color:var(--muted);margin-top:3px}
.wr-expand-icon{color:var(--muted);font-size:.85rem;transition:transform .2s;flex-shrink:0;font-family:inherit}
.wr-body{display:none;padding:0 18px 16px;border-top:1px solid var(--border)}
.wr-body.open{display:block}
.wr-body h4{
  font-family:'Cormorant Garamond',serif;font-size:1rem;font-weight:600;color:var(--primary-dark);
  letter-spacing:.04em;margin:14px 0 8px;
}
.wr-ingr-list{list-style:none;display:flex;flex-direction:column;gap:5px;margin-bottom:12px}
.wr-ingr-list li{font-size:.86rem;padding-left:16px;position:relative;line-height:1.4}
.wr-ingr-list li::before{content:'';position:absolute;left:2px;top:9px;width:5px;height:5px;border-radius:50%;background:var(--primary-light)}
.wr-steps-list{list-style:none;display:flex;flex-direction:column;gap:9px}
.wr-steps-list li{font-size:.86rem;display:flex;align-items:flex-start;gap:10px;line-height:1.45}
.wr-step-num{
  background:var(--primary);color:#fff;width:24px;height:24px;min-width:24px;
  border-radius:50%;display:flex;align-items:center;justify-content:center;
  font-family:'Cormorant Garamond',serif;font-size:.78rem;font-weight:700;flex-shrink:0;margin-top:1px;
}
.batch-badge{
  font-size:.62rem;padding:2px 8px;border-radius:8px;flex-shrink:0;margin-top:4px;
  white-space:nowrap;background:#e2efd0;color:#1a4818;font-weight:600;
  text-transform:uppercase;letter-spacing:.06em;
}
.wr-notes{
  margin-top:12px;font-size:.84rem;color:var(--text-light);
  background:var(--bg);padding:11px 13px;border-radius:8px;line-height:1.55;
  border-left:3px solid var(--accent-soft);
}

/* SHOPPING */
.shopping-container{max-width:1150px;margin:0 auto;display:grid;grid-template-columns:1fr 340px;gap:16px}
@media(max-width:780px){.shopping-container{grid-template-columns:1fr}}
.shopping-list-card{background:var(--card);border-radius:var(--radius);box-shadow:var(--shadow);padding:18px 22px;border:1.5px solid var(--border)}
.shop-toolbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.shop-toolbar h2{
  font-family:'Cormorant Garamond',serif;
  font-size:1.3rem;font-weight:600;color:var(--primary-dark);letter-spacing:.02em;
}
.shop-category{margin-bottom:16px}
.shop-cat-title{
  font-family:'Cormorant Garamond',serif;font-size:.95rem;font-weight:600;
  text-transform:uppercase;letter-spacing:.1em;color:var(--primary);
  margin-bottom:8px;padding-bottom:6px;border-bottom:1px solid var(--border);
}
.shop-item{display:flex;align-items:center;gap:10px;padding:7px 0}
.shop-item input[type=checkbox]{width:16px;height:16px;accent-color:var(--primary);cursor:pointer}
.shop-item label{font-size:.87rem;flex:1;cursor:pointer;line-height:1.35}
.shop-item label.instock{text-decoration:line-through;color:var(--muted)}
.in-stock-badge{font-size:.62rem;background:#e8f0d8;color:#3a5520;border-radius:8px;padding:2px 8px;white-space:nowrap;font-weight:600;letter-spacing:.04em}
.inv-panel{background:var(--card);border-radius:var(--radius);box-shadow:var(--shadow);padding:18px;border:1.5px solid var(--border)}
.inv-panel h3{
  font-family:'Cormorant Garamond',serif;font-size:1.15rem;font-weight:600;
  color:var(--primary-dark);margin-bottom:14px;letter-spacing:.02em;
}
.inv-section-mini{margin-bottom:16px}
.inv-section-mini h4{
  font-family:'Cormorant Garamond',serif;font-size:.85rem;font-weight:600;
  text-transform:uppercase;letter-spacing:.08em;color:var(--primary);margin-bottom:7px;
}
.inv-mini-item{display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-bottom:1px solid var(--bg-2);font-size:.85rem}
.inv-mini-item:last-child{border-bottom:none}
.inv-mini-amt{font-size:.76rem;color:var(--muted)}

/* INVENTORY */
.inventory-container{max-width:980px;margin:0 auto}
.inv-tab-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(290px,1fr));gap:16px}
.inv-card{background:var(--card);border-radius:var(--radius);box-shadow:var(--shadow);padding:18px;border:1.5px solid var(--border)}
.inv-card h3{
  font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:600;color:var(--primary-dark);
  margin-bottom:14px;letter-spacing:.02em;
}
.inv-table{width:100%;border-collapse:collapse;font-size:.85rem}
.inv-table th{
  text-align:left;font-size:.7rem;font-weight:700;color:var(--muted);
  text-transform:uppercase;padding:4px 0 8px;border-bottom:1px solid var(--border);letter-spacing:.06em;
}
.inv-table td{padding:8px 0;border-bottom:1px solid var(--bg-2);vertical-align:middle}
.inv-table tr:last-child td{border-bottom:none}
.inv-del-btn{background:none;border:none;color:var(--muted);cursor:pointer;font-size:.95rem;padding:2px 4px;font-family:inherit}
.inv-del-btn:hover{color:var(--danger)}
.inv-add-row{display:flex;gap:6px;margin-top:12px;flex-wrap:wrap}
.inv-add-row input{flex:1;min-width:0;border:1.5px solid var(--border);border-radius:6px;padding:7px 10px;font-size:.84rem;outline:none;font-family:inherit;background:var(--card);color:var(--text)}
.inv-add-row input:focus{border-color:var(--primary)}
.inv-add-row button{background:var(--primary);color:#fff;border:none;border-radius:6px;padding:7px 14px;font-size:.82rem;cursor:pointer;font-weight:600;white-space:nowrap;font-family:inherit}

/* BUTTONS */
.btn{
  display:inline-flex;align-items:center;gap:6px;padding:8px 18px;
  border-radius:20px;border:none;cursor:pointer;font-size:.85rem;font-weight:600;
  transition:all .2s;font-family:inherit;letter-spacing:.02em;
}
.btn-primary{background:var(--primary);color:#fff}
.btn-primary:hover{background:var(--primary-dark)}
.btn-accent{background:var(--accent);color:#fff}
.btn-accent:hover{background:#a86e4d}
.btn-ghost{background:transparent;color:var(--primary);border:1.5px solid var(--primary)}
.btn-ghost:hover{background:var(--primary);color:#fff}
.btn-danger{background:var(--danger);color:#fff}
.btn-danger:hover{background:#9a4030}
.btn-sm{padding:6px 13px;font-size:.78rem}
.empty-state{text-align:center;padding:48px 20px;color:var(--muted)}
.empty-state .es-title{font-family:'Cormorant Garamond',serif;font-size:1.2rem;color:var(--primary-dark);margin-bottom:6px}
.empty-state p{font-size:.88rem;line-height:1.5}
</style>
</head>
