// ===== DAILY RUN INLINE =====
function renderDailyRunInline(){
  const sun=getWeekSunday(S.weekOffset),td=todayStr();
  let pillsHtml='';
  for(let d=0;d<7;d++){
    const dd=new Date(sun);dd.setDate(sun.getDate()+d);
    const isToday=dayStr(dd)===td;
    pillsHtml+=`<button class="dr-day-pill${focusedDay===d?' active':''}${isToday?' today':''}" onclick="setFocusedDay(${d})">${DAYS[d]} ${dd.getDate()}</button>`;
  }
  const dd=new Date(sun);dd.setDate(sun.getDate()+focusedDay);
  const tasks=getDailyTasks(focusedDay);
  const customTasks=getCustomTasks(focusedDay);
  const allTasks=[...tasks,...customTasks];
  const doneMap=S.prepDone[`${S.weekOffset}|${focusedDay}|all`]||{};
  const mealLabel={breakfast:'Breakfast',lunch:'Lunch',dinner:'Dinner',custom:'Custom'};
  const tasksHtml=allTasks.length?allTasks.map((t,i)=>{
    // For batch tasks (with pid) — completion tracked in S.batchCompleted
    // For meal-day tasks (with pid) — also tracked in S.batchCompleted so carry-forward works
    // For custom tasks — tracked in doneMap
    const done=t.pid?!!(S.batchCompleted&&S.batchCompleted[t.pid]):!!doneMap[i];
    const m=t.meal||'custom';
    const mealPill=`<span class="dr-task-meal meal-${m}">${mealLabel[m]||m}</span>`;
    const carryPill=t.carry?`<span class="dr-task-carry">⚡ carry-over</span>`:'';
    const batchPill=t.batched&&!t.carry?`<span class="dr-task-batch">⏳ batch ahead</span>`:'';
    return`<div class="dr-task meal-${m}-bar${t.carry?' carry':''}${t.batched&&!t.carry?' batch-ahead':''}">
      <input type="checkbox" ${done?'checked':''} onchange="togglePrepTask(${i},this.checked,${t.pid?`'${t.pid}'`:'null'})">
      ${mealPill}
      ${carryPill}${batchPill}
      <span class="dr-task-text${done?' done':''}">${esc(t.text)}</span>
      ${t.recipe?`<span class="dr-task-source${t.batched?' batched':''}">${esc(t.recipe)}</span>`:''}
    </div>`;
  }).join(''):'<div class="dr-empty">No prep tasks for this day. Plan some meals or click below to add a custom task.</div>';

  // Cook-ahead candidates: batchable steps from upcoming meals (next 1-4 days) that aren't yet placed or done
  const cookAheadHtml=getCookAheadCandidates(focusedDay).map(c=>`
    <div class="ca-candidate" draggable="true" data-pid="${c.pid}" ondragstart="caDragStart(event,'${c.pid}')">
      <div class="ca-cand-text">${esc(c.text)}</div>
      <div class="ca-cand-meta">
        <span class="ca-recipe">${esc(c.recipe)}</span>
        <span class="ca-for">for ${DAY_FULL[c.d]} · ${MEAL_LABEL[c.meal]}</span>
        <button class="ca-cand-add" onclick="planCookAhead('${c.pid}',${focusedDay})">+ plan today</button>
      </div>
    </div>`).join('');

  document.getElementById('daily-run').innerHTML=`
    <div class="dr-header">
      <div class="dr-title">Daily Run — ${DAY_FULL[focusedDay]}, ${fmtDate(dd)}</div>
      <div class="dr-day-pills" id="dr-day-pills">${pillsHtml}</div>
    </div>
    <div class="dr-tasks" id="dr-tasks-list" ondragover="event.preventDefault()" ondrop="caDropOnDay(event,${focusedDay})">${tasksHtml}</div>

    <div class="dr-plan-panel">
      <div class="dr-plan-header">
        <span class="dr-plan-title">Plan ahead</span>
        <span class="dr-plan-sub">drag a step to a day pill, or click “+ plan”</span>
      </div>
      ${cookAheadHtml||'<div class="ca-empty">Nothing batchable in the next 4 days yet — plan some meals to see options here.</div>'}
    </div>

    <form class="dr-custom-form" onsubmit="addCustomTaskFromForm(event)">
      <input class="dr-custom-input" id="dr-custom-input" placeholder="Add a custom task for ${DAY_FULL[focusedDay]}…" autocomplete="off">
      <button type="submit" class="dr-custom-btn">+ add task</button>
    </form>
  `;

  // Make day pills accept drops (so user can drag a step from the upcoming list onto another day)
  document.querySelectorAll('#dr-day-pills .dr-day-pill').forEach((pill,d)=>{
    pill.addEventListener('dragover',e=>{e.preventDefault();pill.classList.add('drop-target')});
    pill.addEventListener('dragleave',()=>pill.classList.remove('drop-target'));
    pill.addEventListener('drop',e=>{e.preventDefault();pill.classList.remove('drop-target');caDropOnDay(e,d)});
  });
}

// Cook-ahead candidates: batchable steps from meals planned in the next 4 days (excluding already-placed)
function getCookAheadCandidates(currentDay){
  const placedSet=new Set();
  for(const v of Object.values(S.batchPlacements||{}))for(const p of v)placedSet.add(p);
  const out=[];
  for(let off=1;off<=4;off++){
    const d=currentDay+off;
    if(d>=7)break;
    for(const meal of MEALS){
      const entries=S.plan[pKey(S.weekOffset,d,meal)]||[];
      const rids=[...new Set(entries.map(e=>e.recipeId))];
      for(const rid of rids){
        const r=S.recipes.find(x=>x.id===rid);if(!r||!Array.isArray(r.steps))continue;
        r.steps.forEach((step,idx)=>{
          const obj=typeof step==='string'?{text:step,batchable:false}:step;
          if(!obj.batchable)return;
          const pid=pidOf(rid,idx,S.weekOffset,d,meal);
          if(placedSet.has(pid))return; // already placed somewhere
          if(S.batchCompleted&&S.batchCompleted[pid])return;
          out.push({pid,text:obj.text,recipe:r.name,d,meal});
        });
      }
    }
  }
  return out;
}

let caDragPid=null;
function caDragStart(e,pid){caDragPid=pid;e.dataTransfer.effectAllowed='move';e.dataTransfer.setData('text/plain',pid);}
function caDropOnDay(e,dayIdx){
  e.preventDefault();
  const pid=caDragPid||e.dataTransfer.getData('text/plain');
  if(!pid)return;
  planCookAhead(pid,dayIdx);
  caDragPid=null;
}
function planCookAhead(pid,dayIdx){
  // Place the step on the chosen day's batch placements; remove from any other day first
  for(const k of Object.keys(S.batchPlacements||{})){
    S.batchPlacements[k]=(S.batchPlacements[k]||[]).filter(p=>p!==pid);
  }
  const k=bKey(S.weekOffset,dayIdx);
  if(!S.batchPlacements[k])S.batchPlacements[k]=[];
  if(!S.batchPlacements[k].includes(pid))S.batchPlacements[k].push(pid);
  save();
  if(currentPage==='plan')renderPlanPage();
}
function addCustomTaskFromForm(e){
  e.preventDefault();
  const input=document.getElementById('dr-custom-input');
  const text=(input.value||'').trim();
  if(!text)return;
  const ck=`${S.weekOffset}|${focusedDay}|custom_tasks`;
  if(!S.customTasks[ck])S.customTasks[ck]=[];
  S.customTasks[ck].push({text});
  save();
  input.value='';
  renderDailyRunInline();
}

function getDailyTasks(dayIdx){
  // Tasks for this day = recipe steps from this day's meals,
  // EXCEPT batchable steps that have been placed on a batch day
  const tasks=[];
  // Build set of all placed pids
  const placedSet=new Set();
  for(const v of Object.values(S.batchPlacements||{}))for(const p of v)placedSet.add(p);

  for(const meal of MEALS){
    const entries=S.plan[pKey(S.weekOffset,dayIdx,meal)]||[];
    const rids=[...new Set(entries.map(e=>e.recipeId))];
    for(const rid of rids){
      const r=S.recipes.find(x=>x.id===rid);if(!r||!Array.isArray(r.steps))continue;
      r.steps.forEach((step,idx)=>{
        const obj=typeof step==='string'?{text:step,batchable:false}:step;
        const pid=pidOf(rid,idx,S.weekOffset,dayIdx,meal);
        // If this step is batchable AND placed elsewhere AND already done, skip.
        // If placed elsewhere but NOT done by now, carry forward to today (it must be done today since meal is today).
        if(obj.batchable && placedSet.has(pid)){
          if(S.batchCompleted&&S.batchCompleted[pid])return;
          // Find which batch day held this step
          let batchDayHeld=null;
          for(const k of Object.keys(S.batchPlacements||{})){
            if((S.batchPlacements[k]||[]).includes(pid)){
              const parts=k.split('|');
              batchDayHeld=Number(parts[1]);
              break;
            }
          }
          // If we're past the batch day (today is the meal day = recipe day), carry it forward as urgent
          tasks.push({text:obj.text,recipe:r.name+' (was scheduled '+(batchDayHeld!==null?DAY_FULL[batchDayHeld]:'earlier')+', not done)',batched:true,carry:true,meal,pid});
          return;
        }
        tasks.push({text:obj.text,recipe:r.name,batched:false,meal,pid});
      });
    }
  }
  // Add batch-day placements: today's batch placements (recipe is for a future day, but step is done today)
  const batchHere=S.batchPlacements[bKey(S.weekOffset,dayIdx)]||[];
  for(const pid of batchHere){
    if(S.batchCompleted&&S.batchCompleted[pid])continue; // already done
    const resolved=resolveStep(pid);
    if(resolved){
      const isFutureRecipe=resolved.srcW>S.weekOffset||(resolved.srcW===S.weekOffset&&resolved.srcD>dayIdx);
      if(!isFutureRecipe)continue; // recipe is today or past — handled above as carry
      tasks.push({text:resolved.text,recipe:resolved.recipe+' (batch for '+DAY_FULL[resolved.srcD]+')',batched:true,meal:resolved.srcM,pid});
    }
  }
  return tasks;
}
function getCustomTasks(dayIdx){
  const ck=`${S.weekOffset}|${dayIdx}|custom_tasks`;
  return (S.customTasks[ck]||[]).map(c=>({text:c.text,recipe:null,batched:false,meal:'custom'}));
}
function togglePrepTask(idx,done,pid){
  if(pid){
    if(!S.batchCompleted)S.batchCompleted={};
    if(done)S.batchCompleted[pid]=true;
    else delete S.batchCompleted[pid];
  }else{
    const k=`${S.weekOffset}|${focusedDay}|all`;
    if(!S.prepDone[k])S.prepDone[k]={};
    S.prepDone[k][idx]=done;
  }
  save();renderDailyRunInline();
}
