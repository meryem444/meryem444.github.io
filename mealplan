    <ul class="bp-healing-list">
      ${healing.map(h=>`<li><strong>${esc(h.name)}.</strong> ${esc(h.benefits.length>240?h.benefits.slice(0,237)+'…':h.benefits)}</li>`).join('')}
    </ul>
  `:'';

  return`
    <div class="bp-section-label">Method</div>
    ${stepsHtml?`<ol class="bp-steps-list">${stepsHtml}</ol>`:'<div style="color:var(--muted);font-style:italic;font-size:.8rem">No steps recorded.</div>'}
    ${r.notes?`<div class="bp-notes">${esc(r.notes)}</div>`:''}
    ${nutritionHtml}
    ${healingHtml}
  `;
}
