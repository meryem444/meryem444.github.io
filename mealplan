const TOC_KEYS=new Set(TOC_SECTIONS.map(s=>s.key));
// Map old / legacy section names to the new ones, so already-tagged recipes still slot in.
const TOC_LEGACY_MAP={
  'Apothecary':'Broths & Infusions',
  'Snacks & Appetizers':'Dips & Energy Bites',
  'Soups':'Broths & Healing Soups',
  'Salads':'Nourishing Salads',
  'Breakfast Favorites':'Eggs & Savory Breakfasts',
  'One Pot Meals':'One-Pan & Sheet Pan Meals',
  'Casseroles':'Casseroles & Bakes',
  'Pasta, Noodles & Rice':'Pasta Grains & Rice',
  'Pasta Noodles & Rice':'Pasta Grains & Rice',
  'Baked Goods':'Breads & Wholesome Bakes',
  'Smoothies & Drinks':'Smoothies & Breakfast Drinks',
  'Desserts':'Cakes & Desserts',
  'Main Course':'One-Pan & Sheet Pan Meals',
};

function recipeCookbookSection(r){
  // 1. If Notion already gave us a Section, trust it (mapping legacy → new where needed).
  if(r&&r.section){
    if(TOC_KEYS.has(r.section))return r.section;
    if(TOC_LEGACY_MAP[r.section])return TOC_LEGACY_MAP[r.section];
  }
  const name=(r?.name||'').toLowerCase();
  const tags=(r?.tags||[]).map(t=>String(t).toLowerCase());
  const all=name+' '+tags.join(' ');

  // 2. Apothecary cluster
  if(/(sauerkraut|kefir|kimchi|miso|fermented|sourdough starter|natto)/.test(all))return'Fermented Foods';
  if(/(bone broth|broth|infusion|herbal tea|kombucha|kvass)/.test(all))return'Broths & Infusions';
  if(/(fire cider|tonic|elixir|tincture|home remedy)/.test(all))return'Tonics & Home Remedies';
  if(/(jam|jelly|pickle|preserve|chutney|relish|marmalade)/.test(all))return'Jams & Preserves';

  // 3. Drinks & smoothies — split breakfast vs general
  if(tags.includes('breakfast')&&/(smoothie|latte|matcha)/.test(name))return'Smoothies & Breakfast Drinks';
  if(tags.includes('smoothie')||/(smoothie|protein shake|frappe)/.test(name))return'Smoothies & Juices';
  if(/(juice|tea|tonic latte|wellness drink|adaptogen)/.test(name))return'Teas & Wellness Drinks';

  // 4. Sweets
  if(/(cookie|brownie|granola bar|protein bar|bar$|bars$)/.test(name))return'Cookies & Bars';
  if(/(cake|pie|crumble|cobbler|ice cream|sorbet|pudding|fudge|truffle|tart|dessert)/.test(name))return'Cakes & Desserts';
  if(/(bread|loaf|focaccia|bun|roll|pizza dough|crust|tortilla|sourdough|baguette)/.test(name))return'Breads & Wholesome Bakes';
  if(/(muffin|scone|biscuit|coffee cake|breakfast bread)/.test(name))return'Muffins & Morning Bakes';

  // 5. Mornings
  if(tags.includes('breakfast')||/(pancake|waffle|french toast|crepe|breakfast)/.test(name)){
    if(/(porridge|oatmeal|bowl|granola|chia|yogurt parfait|acai|smoothie bowl)/.test(name))return'Breakfast Bowls & Porridges';
    if(/(egg|frittata|omelet|omelette|shakshuka|scramble|hash)/.test(name))return'Eggs & Savory Breakfasts';
    return'Eggs & Savory Breakfasts';
  }
  if(/(porridge|oatmeal|chia pudding|granola|smoothie bowl|acai)/.test(name))return'Breakfast Bowls & Porridges';

  // 6. Lunch & lighter
  if(/(salad|slaw|tabbouleh)/.test(name))return'Nourishing Salads';
  if(/(wrap|sandwich|pita|taco|burrito|toast|quesadilla)/.test(name))return'Wraps & Light Lunches';
  if(/(soup|stew|chowder|bisque|ramen|pho)/.test(name)){
    if(/(broth|healing|bone broth|chicken broth)/.test(name))return'Broths & Healing Soups';
    return'Soups & Stews';
  }

  // 7. Dinners / mains
  if(/casserole|gratin|baked /.test(name))return'Casseroles & Bakes';
  if(/(pasta|noodle|spaghetti|lasagna|linguini|fettucine|penne|risotto|orzo|fried rice|rice bowl|pilaf|quinoa|grain bowl)/.test(all))return'Pasta Grains & Rice';
  if(/(sheet pan|one pan|one-pan|skillet|tray bake)/.test(all))return'One-Pan & Sheet Pan Meals';

  // 8. Snacky things
  if(tags.includes('snack')||/(dip|guac|pesto|hummus|tapenade|spread|energy bite|energy ball|fat bomb|cracker|pâté|paté|pate)/.test(name))return'Dips & Energy Bites';

  // 9. Default — treat as a one-pan main if it sounds like cooked protein
  if(/(chicken|beef|fish|salmon|pork|lamb|sardine|turkey|tuna|shrimp|scallop|cod|stir fry|tagine|curry|chili|braised|roast|grilled|seared)/.test(all))return'One-Pan & Sheet Pan Meals';
  return'Other';
}

function bookGroupBySections(recipes){
  const groups={};
  for(const r of recipes){
    const sec=recipeCookbookSection(r);
    (groups[sec]=groups[sec]||[]).push(r);
  }
  // Keep TOC order, drop empty sections
  return TOC_SECTIONS.map(s=>({name:s.key,cls:s.cls,part:s.part,items:groups[s.key]||[]})).filter(g=>g.items.length);
}

// Render the TOC entries grouped by part heading.
// `sections` is a sequential slice of groups (each {name, cls, part, items}).
function bookRenderSectionList(sections){
  if(!sections.length)return'';
  let html='';
  let currentPart=null;
  for(const g of sections){
    if(g.part!==currentPart){
      currentPart=g.part;
      // Skip the part header for the catch-all "Other" bucket
      if(currentPart&&currentPart!=='Other'){
        html+=`<div class="toc-part-heading">${esc(currentPart)}</div>`;
      }
    }
    const cls=`sec-${g.cls||g.name.toLowerCase().replace(/\s+/g,'-')}`;
    const entries=g.items.map(r=>{
      const idx=bookState.filtered.indexOf(r)+1;
      return `<div class="toc-entry" onclick="bookGotoRecipeIdx(${idx-1})">
        <span class="toc-entry-name">${esc(r.name||'Untitled')}</span>
        <span class="toc-entry-leader"></span>
        <span class="toc-entry-num">${idx}</span>
      </div>`;
    }).join('');
    html+=`<div class="toc-section">
      <div class="toc-section-label ${cls}">${esc(g.name)}</div>
      ${entries}
    </div>`;
  }
  return html;
}

function bookRenderTOCLeftPage(){
  // Title + half the sections on the left page
  const groups=bookGroupBySections(bookState.filtered);
  if(!groups.length){
    return`<div class="toc-page"><div class="toc-title">Table of Contents</div><div style="color:var(--muted);font-style:italic;font-size:.88rem">No recipes match — try removing a filter from the toolbar.</div></div>`;
  }
  const {left}=bookSplitTOCByPart(groups);
  return`<div class="toc-page">
    <div class="toc-title">Table of Contents</div>
    ${bookRenderSectionList(left)}
  </div>`;
}

// Split the TOC across two pages without breaking a Part across pages.
// Returns {left,right}.
function bookSplitTOCByPart(groups){
  const total=groups.reduce((s,g)=>s+g.items.length,0);
  if(total===0)return{left:groups,right:[]};
  // Group consecutively by part
  const byPart=[];
  for(const g of groups){
    if(byPart.length&&byPart[byPart.length-1].part===g.part){
      byPart[byPart.length-1].groups.push(g);
      byPart[byPart.length-1].count+=g.items.length;
    }else{
      byPart.push({part:g.part,groups:[g],count:g.items.length});
    }
  }
  // Take whole parts onto the left page until adding the next part would exceed ~60% of total
  const target=Math.ceil(total*0.55);
  let count=0,splitIdx=byPart.length;
  for(let i=0;i<byPart.length;i++){
    if(count>0&&count+byPart[i].count>target){splitIdx=i;break;}
    count+=byPart[i].count;
  }
  const left=byPart.slice(0,splitIdx).flatMap(p=>p.groups);
  const right=byPart.slice(splitIdx).flatMap(p=>p.groups);
  return{left,right};
}

function bookRenderTOCRightPage(){
  const groups=bookGroupBySections(bookState.filtered);
  if(!groups.length)return'';
  const {right}=bookSplitTOCByPart(groups);
  if(right.length){
    return`<div class="toc-page">
      ${bookRenderSectionList(right)}
    </div>`;
  }
  // If everything fits on left, use right page for "this week" recommendations
  const recs=bookComputeRecommendations().slice(0,8);
  const recHtml=recs.map(r=>{
    const idx=bookState.filtered.indexOf(r);
    const onclick=idx>=0?`onclick="bookGotoRecipeIdx(${idx})"`:`onclick="bookJumpToRecipe('${r.id}')"`;
    return`<li ${onclick}>${esc(r.name||'')}</li>`;
  }).join('');
  return`<div class="toc-right-pane">
    <div class="toc-rp-title">For this week</div>
    <div class="toc-rp-section">
      <div class="toc-rp-label">Suggested by your algorithm</div>
      <ul class="toc-rp-list">${recHtml}</ul>
    </div>
    <div class="toc-rp-section">
      <div class="toc-rp-label">In season now</div>
      <div style="font-size:.78rem;color:var(--text-light);font-style:italic;line-height:1.6">May produce: strawberries, asparagus, peas, lettuce, broccoli, blueberries, lime, lettuce.</div>
    </div>
  </div>`;
}

function bookGotoRecipeIdx(idx){
  if(idx<0||idx>=bookState.filtered.length)return;
  bookState.tocMode=false;
  bookState.spread=idx;
  bookRender();
}

function bookGotoTOC(){
  bookState.tocMode=true;
