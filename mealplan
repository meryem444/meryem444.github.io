function removeEntry(person,recipeId){
  const key=pKey(S.weekOffset,popDay,popMeal);
  const entries=S.plan[key]||[];
  const idx=entries.findIndex(e=>e.person===person&&e.recipeId===recipeId);
  if(idx!==-1)entries.splice(idx,1);
  S.plan[key]=entries;save();
  // Also clean up batch placements that referenced this recipe at this slot
  for(const k of Object.keys(S.batchPlacements||{})){
    S.batchPlacements[k]=(S.batchPlacements[k]||[]).filter(pid=>{
      const m=pid.match(/^(.+)@(\d+)@(-?\d+)\|(\d+)\|([a-z]+)$/);
