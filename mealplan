function bookTimeMinutes(r){
  // r.time is a free string like "20 min" or "3h IP / 24h stovetop"
  const t=String(r.time||'').toLowerCase();
  const hMatch=t.match(/(\d+)\s*h/);
  const mMatch=t.match(/(\d+)\s*m/);
  const h=hMatch?parseInt(hMatch[1]):0;
  const m=mMatch?parseInt(mMatch[1]):0;
  return h*60+m;
}
function bookApplyFilters(){
  const q=bookState.search;
  const now=getSeasonOfMonth(new Date().getMonth());
  return (S.recipes||[]).filter(r=>{
    if(q){
      const hay=[r.name,(r.tags||[]).join(' '),(r.ingredients||[]).map(i=>i.name).join(' '),r.notes||'',r.time||''].join(' ').toLowerCase();
      if(!hay.includes(q))return false;
    }
    for(const f of bookState.filters){
      if(f.type==='meal'){
        // Match against tags (Breakfast/Lunch/Dinner/Snack/Smoothie/Drink)
        if(!bookHasTag(r,f.label))return false;
      }else if(f.type==='cuisine'){
        if(!bookHasTag(r,f.value))return false;
      }else if(f.type==='person'){
        if(f.value==='arya'){
          // Arya has explicit arya_safe flag
          if(r.arya_safe===false)return false;
          if(!recipeIsSafeFor(r,'arya'))return false;
        }else{
          if(!recipeIsSafeFor(r,f.value))return false;
        }
      }else if(f.type==='season'){
        const s=f.value==='now'?now:f.value;
        if(!recipeIsSeasonal(r,s))return false;
      }else if(f.type==='diet'){
        if(f.value==='batchable'){
          const hasBatch=bookHasTag(r,'Batch')||(r.steps||[]).some(s=>(typeof s==='object'?s.batchable:false));
          if(!hasBatch)return false;
        }else if(f.value==='quick'){
          const t=bookTimeMinutes(r);
          if(t===0||t>=30)return false;
        }
      }
    }
    return true;
  });
}

