<header id="app-header">
  <h1>Family Meal Plan</h1>
  <nav id="nav">
    <button class="nav-btn active" onclick="showPage('plan',this)">Plan</button>
    <button class="nav-btn" onclick="showPage('recipe-book',this)">Recipes</button>
