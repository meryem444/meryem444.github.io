// ===== WEEKLY RECOMMENDATIONS =====
// Algorithm v1: 2 meat (1 steak, 1 ancestral), 3 fish/seafood, rest flexible (plant or chicken).
// Bias toward seasonal produce when nothing yet planned for the week.
function recipeProteinType(r){
  const ings=(r.ingredients||[]).map(i=>(i.name||'').toLowerCase()).join(' ');
  const tags=(r.tags||[]).map(t=>String(t).toLowerCase()).join(' ');
  const all=ings+' '+tags;
  if(/(salmon|sardine|tuna|mackerel|halibut|cod|haddock|trout|seabass|snapper|tilapia|anchovy|herring|fish|shrimp|prawn|lobster|crab|squid|calamari|mussels|oyster|seafood)/.test(all))return'fish';
  if(/(steak|ribeye|sirloin|brisket|short rib|chuck)/.test(all))return'steak';
  if(/(ancestral blend|liver|heart|organ)/.test(all))return'ancestral';
  if(/(beef|ground beef|burger|meatball|lamb|mutton|pork|bacon|sausage)/.test(all))return'meat';
  if(/(chicken|turkey|duck|goose)/.test(all))return'chicken';
  if(/(lentil|chickpea|black bean|tofu|tempeh|quinoa|plant)/.test(all)||tags.includes('plant-based')||tags.includes('vegan'))return'plant';
  return'other';
}
function bookComputeRecommendations(){
  // Returns up to 8 recipes following the algorithm.
  const all=(S.recipes||[]).slice();
  const now=getSeasonOfMonth(new Date().getMonth());
  // Buckets
  const buckets={steak:[],ancestral:[],fish:[],meat:[],chicken:[],plant:[],other:[]};
  for(const r of all){
    const w=recipeWarnings(r);
    // Skip if Arya has a hard reactivity — she's the most restricted, family meals must be safe for her
    // (User confirmed eggs/coconut OK so we don't auto-block those — keep heuristic permissive)
    buckets[recipeProteinType(r)].push(r);
  }
  // Boost seasonal recipes within each bucket
  const boost=arr=>arr.sort((a,b)=>{
    const sa=recipeIsSeasonal(a,now)?1:0;
    const sb=recipeIsSeasonal(b,now)?1:0;
    return sb-sa;
  });
  Object.keys(buckets).forEach(k=>boost(buckets[k]));
  const picks=[];
  const take=(arr,n)=>{const out=arr.slice(0,n);for(const x of out)if(!picks.some(p=>p.id===x.id))picks.push(x)};
  take(buckets.steak,1);
  take(buckets.ancestral,1);
  // Fallback if no steak/ancestral specifically tagged: substitute from generic meat
  if(picks.filter(r=>['steak','ancestral'].includes(recipeProteinType(r))).length<2){
    take(buckets.meat,2-picks.filter(r=>['steak','ancestral','meat'].includes(recipeProteinType(r))).length);
  }
  take(buckets.fish,3);
  // Rest flexible — plant first if seasonal, then chicken
  const flexNeed=8-picks.length;
  const flexPool=[...buckets.plant,...buckets.chicken,...buckets.other,...buckets.meat];
  take(flexPool,flexNeed);
  return picks.slice(0,8);
}
function bookRenderRecs(){
  const recs=bookComputeRecommendations();
  const strip=document.getElementById('book-recs-strip');
  if(!recs.length){strip.innerHTML='<div style="color:var(--muted);font-style:italic;font-size:.7rem;padding:8px">No recipes yet</div>';return}
  strip.innerHTML=recs.map(r=>{
    const photo=r.photo?`<div class="rec-photo" style="background-image:url('${r.photo}')"></div>`:`<div class="rec-photo">no photo</div>`;
    const type=recipeProteinType(r);
    const typeClass=type==='fish'?'fish':(['plant','other'].includes(type)?'plant':'protein');
    const typeLabel=type==='fish'?'Fish':type==='plant'?'Plant':type==='chicken'?'Chicken':type==='steak'?'Steak':type==='ancestral'?'Ancestral':type==='meat'?'Meat':'Other';
    return`<div class="rec-card" onclick="bookJumpToRecipe('${r.id}')" title="${esc(r.name)}">
      ${photo}
      <div class="rec-name">${esc(r.name||'')}</div>
      <div class="rec-tag ${typeClass}">${typeLabel}</div>
    </div>`;
  }).join('');
}
function bookJumpToRecipe(rid){
  // Open the book panel and jump straight to that recipe's spread (out of TOC mode)
  if(!bookState.open){openBook(null,null)}
  // Clear filters so the target recipe definitely appears in the list
  bookState.filters=[];
  bookState.search='';
  const sb=document.getElementById('book-search');
  if(sb)sb.value='';
  bookState.filtered=bookApplyFilters();
  const idx=bookState.filtered.findIndex(r=>r.id===rid);
  if(idx<0){console.warn('Recipe not found in book:',rid);return;}
  bookState.tocMode=false; // <-- critical: leave the table of contents
  bookState.spread=idx;
  bookRender();
}
