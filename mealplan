  evt.target.classList.add('dragging');
}
function batchDragEnd(evt){
  evt.target.classList.remove('dragging');
  document.querySelectorAll('.drop-target').forEach(e=>e.classList.remove('drop-target'));
  dragPid=null;
}
function handleBatchPopupDrop(evt){
  evt.preventDefault();
  evt.currentTarget.classList.remove('drop-target');
  const pid=evt.dataTransfer.getData('text/plain')||dragPid;
  if(pid)toggleBatchPlacement(pid,true);
}
function handleBatchDrop(evt,dayIdx){
  evt.preventDefault();
  evt.currentTarget.classList.remove('drop-target');
  const pid=evt.dataTransfer.getData('text/plain')||dragPid;
  if(!pid)return;
  // Move pid into batch day dayIdx
  for(const otherK of Object.keys(S.batchPlacements||{})){
    S.batchPlacements[otherK]=(S.batchPlacements[otherK]||[]).filter(x=>x!==pid);
    if(!S.batchPlacements[otherK].length)delete S.batchPlacements[otherK];
  }
  const k=bKey(S.weekOffset,dayIdx);
  if(!S.batchPlacements[k])S.batchPlacements[k]=[];
  S.batchPlacements[k].push(pid);
  save();
  if(currentPage==='plan')renderPlanPage();
}

