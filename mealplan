// Hardcoded seasonal lookup for v1 (later: pull from Notion ingredient season tags)
const SEASONAL_INGREDIENTS={
  spring:['asparagus','strawberr','pea','radish','rhubarb','spring onion','artichoke','fennel','spinach','arugula','rocket','sorrel'],
  summer:['tomato','cucumber','zucchini','corn','watermelon','peach','plum','nectarine','blueberr','raspberr','blackberr','basil','eggplant','bell pepper','capsicum','melon'],
  fall:['butternut','pumpkin','sweet potato','apple','pear','cranberr','brussels','cauliflower','kale','beet','parsnip','squash','fig','grape'],
  winter:['kale','cabbage','carrot','leek','onion','potato','sweet potato','citrus','orange','grapefruit','lemon','lime','pomegranate','turnip','swede','rutabaga'],
};
function getSeasonOfMonth(m){ // m: 0-11
  if(m>=2&&m<=4)return'spring';
  if(m>=5&&m<=7)return'summer';
  if(m>=8&&m<=10)return'fall';
  return'winter';
}
function recipeIsSeasonal(r,season){
  const ings=(r.ingredients||[]).map(i=>(i.name||'').toLowerCase()).join(' ');
  return SEASONAL_INGREDIENTS[season].some(k=>ings.includes(k));
}

// Reactivity check (v1 — heuristic by ingredient-name keywords; will be replaced once we sync from Notion)
const REACTIVE={
  meryem:['wheat','bread','rice','peanut','hemp','banana','rapeseed','canola','celery','dairy','milk','cheese','butter','yogurt','kefir','cream','lentil','sunflower','corn','maize','polenta','popcorn','sesame','tahini'],
  austin:['wheat','bread','rice','peanut','dairy','milk','cheese','butter','yogurt','kefir','cream','coconut','sesame','tahini','mushroom','hazelnut','chickpea','garbanzo','kidney','rye','rapeseed','canola','calamari','squid','dill','tarragon','shrimp','prawn','vermouth','whisky'],
  arya:['wheat','bread','peanut','dairy','milk','cheese','butter','yogurt','kefir','cream','soy','tofu','tempeh','miso','natto','edamame','egg','cannellini','sesame','tahini','apple','cider','crab','cod','haddock','lamb','mutton','veal','pine nut','liver','sweetbread','pork sausage'],
};
function recipeWarnings(r){
  const ings=(r.ingredients||[]).map(i=>(i.name||'').toLowerCase()).join(' ');
  const w={};
  for(const p of ['meryem','austin','arya']){
    const hits=REACTIVE[p].filter(k=>ings.includes(k));
    if(hits.length)w[p]=hits[0]; // first match
  }
  return w;
}
