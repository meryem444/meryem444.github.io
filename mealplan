// RIGHT PAGE: steps + nutrition + healing properties
function bookRenderRightPage(r){
  if(!r)return'';
  const stepsHtml=(r.steps||[]).map(s=>{
    const text=typeof s==='string'?s:(s.text||'');
    const isBatch=typeof s==='object'&&s.batchable;
    return`<li class="${isBatch?'batch':''}">${esc(text)}</li>`;
  }).join('');

  // Nutrition: prefer Notion rollup totals if present, else compute from ingredients × library
  const servings=parseFloat(r.servings)||1;
  let totalCal=r.total_calories,totalPr=r.total_protein,totalCb=r.total_carbs,totalFa=r.total_fat,totalFi=r.total_fiber;
  if(totalCal==null){
    const n=computeRecipeNutrition(r);
    if(n){totalCal=n.calories;totalPr=n.protein;totalCb=n.carbs;totalFa=n.fat;totalFi=n.fiber;}
  }
  const fmt=n=>n==null?'—':(Math.round(n*10)/10);
  const perServ=n=>n==null?'—':(Math.round((n/servings)*10)/10);
  const nutritionHtml=(totalCal!=null)?`
    <div class="bp-section-label" style="margin-top:14px">Nutrition</div>
    <table class="bp-nutri">
      <thead><tr><th></th><th>Total</th><th>Per serving (${servings})</th></tr></thead>
      <tbody>
        <tr><td>Calories</td><td>${fmt(totalCal)}</td><td>${perServ(totalCal)}</td></tr>
        <tr><td>Protein (g)</td><td>${fmt(totalPr)}</td><td>${perServ(totalPr)}</td></tr>
        <tr><td>Carbs (g)</td><td>${fmt(totalCb)}</td><td>${perServ(totalCb)}</td></tr>
        <tr><td>Fat (g)</td><td>${fmt(totalFa)}</td><td>${perServ(totalFa)}</td></tr>
        <tr><td>Fiber (g)</td><td>${fmt(totalFi)}</td><td>${perServ(totalFi)}</td></tr>
      </tbody>
    </table>
  `:'';

  // Healing properties: aggregate per-ingredient benefits
  const healing=recipeHealingNotes(r);
  const allCompounds=[...new Set(healing.flatMap(h=>h.compounds))].slice(0,12);
  const healingHtml=healing.length?`
    <div class="bp-section-label" style="margin-top:14px">Healing properties</div>
