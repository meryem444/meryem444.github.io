function getSyncCfg(){return JSON.parse(localStorage.getItem('mealplan_sync_cfg')||'{}');}
function saveSyncCfg(cfg){localStorage.setItem('mealplan_sync_cfg',JSON.stringify(cfg));}

function openSyncSettings(){
  const cfg=getSyncCfg();
  document.getElementById('sync-worker-url').value=cfg.workerUrl||'';
  document.getElementById('sync-worker-key').value=cfg.syncKey||'';
  document.getElementById('sync-test-result').textContent='';
  document.getElementById('sync-test-result').className='sync-test-result';
  document.getElementById('sync-settings-overlay').classList.add('open');
}
function closeSyncSettings(){document.getElementById('sync-settings-overlay').classList.remove('open');}
function saveSyncSettings(){
  const workerUrl=document.getElementById('sync-worker-url').value.trim().replace(/\/+$/,'');
  const syncKey=document.getElementById('sync-worker-key').value.trim();
  saveSyncCfg({workerUrl,syncKey});
  closeSyncSettings();
