// Compute the total grams for a recipe ingredient given amount + unit + linked Notion data
function computeIngredientGrams(ing,libEntry){
  const amt=parseFloat(ing.amount)||0;
  if(!amt)return 0;
  const unit=(ing.unit||'').toLowerCase();
  // Direct gram-equivalent units
  if(unit==='g')return amt;
  if(unit==='kg')return amt*1000;
  if(unit==='oz')return amt*28.35;
  if(unit==='lb')return amt*453.59;
  if(unit==='ml')return amt; // approx for water-based; close enough for cooking
  // Volume/piece-based: use ingredient's per-unit conversion if we have it
  if(libEntry){
    if(unit==='tsp'&&libEntry.g_per_tsp)return amt*libEntry.g_per_tsp;
    if(unit==='tbsp'&&libEntry.g_per_tbsp)return amt*libEntry.g_per_tbsp;
    if(unit==='cup'&&libEntry.g_per_cup)return amt*libEntry.g_per_cup;
    if(unit==='piece'&&libEntry.g_per_piece)return amt*libEntry.g_per_piece;
    if(unit==='scoop'&&libEntry.g_per_piece)return amt*libEntry.g_per_piece;
    if(unit==='clove'&&libEntry.g_per_piece)return amt*libEntry.g_per_piece;
  }
  return 0; // unknown — won't contribute to totals
}
// Compute total nutrition for a recipe by summing each ingredient × grams × per-100g data
function computeRecipeNutrition(r){
  if(!r||!Array.isArray(r.ingredients))return null;
  const lib=S.ingredientsLib||[];
  const byPid={};for(const i of lib)byPid[i.pageId]=i;
  // Match by page-id first, then fall back to name match
  let cal=0,pr=0,cb=0,fa=0,fi=0,knownGrams=0,unknownNames=[];
  for(const ing of r.ingredients){
    let lib_=null;
    if(ing.ingPageId&&byPid[ing.ingPageId])lib_=byPid[ing.ingPageId];
    else{
      const n=(ing.name||'').toLowerCase();
      lib_=lib.find(x=>(x.name||'').toLowerCase()===n)||null;
      if(!lib_){unknownNames.push(ing.name);continue;}
    }
    const grams=computeIngredientGrams(ing,lib_);
    if(!grams||!lib_.cal_per_100g){continue;}
    knownGrams+=grams;
    const factor=grams/100;
    cal+=(lib_.cal_per_100g||0)*factor;
    pr+=(lib_.protein_per_100g||0)*factor;
    cb+=(lib_.carbs_per_100g||0)*factor;
    fa+=(lib_.fat_per_100g||0)*factor;
    fi+=(lib_.fiber_per_100g||0)*factor;
  }
  return {calories:cal,protein:pr,carbs:cb,fat:fa,fiber:fi,knownGrams,unknownNames};
}
// Aggregate healing benefits from ingredients
function recipeHealingNotes(r){
  if(!r||!Array.isArray(r.ingredients))return[];
  const lib=S.ingredientsLib||[];
  const byPid={};for(const i of lib)byPid[i.pageId]=i;
  const out=[];const seen=new Set();
  for(const ing of r.ingredients){
    let lib_=null;
    if(ing.ingPageId&&byPid[ing.ingPageId])lib_=byPid[ing.ingPageId];
    else{
      const n=(ing.name||'').toLowerCase();
      lib_=lib.find(x=>(x.name||'').toLowerCase()===n)||null;
    }
    if(!lib_||!lib_.healing||seen.has(lib_.pageId))continue;
    seen.add(lib_.pageId);
    out.push({name:lib_.name,benefits:lib_.healing,compounds:lib_.compounds||[]});
  }
  return out;
}

// AUTO-TAG COMPUTATION
// Paleo/Keto badges only appear if the heuristic check on every ingredient name passes.
// Person warnings only appear if any ingredient matches that person's reactivity list.
function recipeAutoTags(r){
  const ings=(r.ingredients||[]).map(i=>(i.name||'').toLowerCase());
  if(!ings.length)return[];
  const tags=[];
  // Non-paleo keywords:
  const nonPaleo=/(wheat|bread|flour|noodle|rice|oat|barley|rye|spelt|farro|kamut|teff|bulgur|seitan|pasta|lasagna|legume|lentil|bean|chickpea|peanut|soy|tofu|tempeh|miso|natto|dairy|milk|cheese|yogurt|butter|cream|kefir|sugar|corn|maize|polenta|popcorn)/;
  const allPaleo=ings.every(i=>!nonPaleo.test(i));
  if(allPaleo)tags.push({label:'Paleo',cls:'paleo'});
  // Keto: low-carb. Disqualify if obvious carbs.
  const nonKeto=/(rice|pasta|bread|flour|potato|sweet potato|banana|date|honey|sugar|maple|apple|pear|grape|mango|raisin|oat|corn|maize|cornflakes|popcorn|polenta|chickpea|lentil|bean|fig|prune)/;
  const allKeto=ings.every(i=>!nonKeto.test(i));
  if(allKeto)tags.push({label:'Keto',cls:'keto'});
  return tags;
}
