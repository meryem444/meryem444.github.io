function openRecipeEditor(id){
  edId=id;
  const r=id?S.recipes.find(x=>x.id===id):null;
  edPhoto=r?.photo||null;edTags=r?[...(r.tags||[])]:[];
  document.getElementById('editor-title').textContent=r?'Edit Recipe':'Add Recipe';
  document.getElementById('ed-name').value=r?.name||'';
  document.getElementById('ed-servings').value=r?.servings||'';
  document.getElementById('ed-time').value=r?.time||'';
  document.getElementById('ed-notes').value=r?.notes||'';
  // Populate Section + Cuisine straight from Notion's schema (so newly-added options like "Main Course" show up)
  const opts=S.notionOptions||{};
  populateSelect('ed-section',opts.recipeSection||[],r?.section||'','— pick a section —');
  populateSelect('ed-cuisine',opts.recipeCuisine||[],r?.cuisine||'','— optional —');
  document.getElementById('ed-delete-btn').style.display=r?'inline-flex':'none';
  updatePhotoPreview();
  renderIngredientRows(r?.ingredients||[]);
  renderStepRows(r?.steps||[]);
  document.getElementById('recipe-editor-overlay').classList.add('open');
}
function closeRecipeEditor(evt){
  if(evt&&evt.target!==document.getElementById('recipe-editor-overlay'))return;
  closeRecipeEditorDirect();
}
function closeRecipeEditorDirect(){document.getElementById('recipe-editor-overlay').classList.remove('open');renderRecipeBook();}
function updatePhotoPreview(){
  document.getElementById('photo-preview-area').innerHTML=edPhoto
    ?`<img src="${edPhoto}" style="max-height:160px;border-radius:8px;margin-bottom:8px"><br><span class="photo-upload-area-text">Click to change</span>`
    :`<div class="photo-upload-area-icon">Photo</div><div class="photo-upload-area-text">Click to upload</div>`;
}
function handlePhotoUpload(evt){
  const file=evt.target.files[0];if(!file)return;
  const reader=new FileReader();
  reader.onload=e=>{edPhoto=e.target.result;updatePhotoPreview();};
  reader.readAsDataURL(file);
}
function toggleTag(pill){
  const tag=pill.dataset.tag;
  if(edTags.includes(tag)){edTags=edTags.filter(t=>t!==tag);pill.classList.remove('selected');}
  else{edTags.push(tag);pill.classList.add('selected');}
}
function renderIngredientRows(ingrs){
  const c=document.getElementById('ingr-list');c.innerHTML='';
  const list=Array.isArray(ingrs)?ingrs:[];
  if(!list.length){appendIngrRow('','','',c);return;}
  for(const i of list){
    const name=typeof i==='string'?i:(i.name||'');
    const amount=typeof i==='object'?(i.amount||''):'';
    const unit=typeof i==='object'?(i.unit||''):'';
    const ingPid=typeof i==='object'?(i.ingPageId||''):'';
    appendIngrRow(name,amount,unit,c,ingPid);
  }
}
// Fallback list — only used until the first Notion sync populates S.notionOptions.componentUnit
const RECIPE_UNITS_FALLBACK=['g','oz','lb','kg','tsp','tbsp','cup','ml','piece','scoop','clove','pinch','bunch','sprig','can','jar'];
function getUnitList(){
  const fromNotion=S?.notionOptions?.componentUnit;
  return (Array.isArray(fromNotion)&&fromNotion.length)?fromNotion:RECIPE_UNITS_FALLBACK;
}
function appendIngrRow(name,amount,unit,container,ingPageId){
  const div=document.createElement('div');div.className='ingr-row';
  const dataAttr=ingPageId?` data-ing-page="${ingPageId}"`:'';
  const units=getUnitList();
  // If unit is set but not in the synced list (legacy data), include it so it stays selected
  const includeCurrent=unit&&!units.includes(unit);
  const unitOpts=(includeCurrent?`<option value="${esc(unit)}" selected>${esc(unit)} (local)</option>`:'')+
    units.map(u=>`<option value="${esc(u)}"${u===unit?' selected':''}>${esc(u)}</option>`).join('');
  div.innerHTML=`
    <div class="ingr-search-wrap">
      <input class="ingr-name" placeholder="Search ingredient…" value="${esc(name)}"${dataAttr} oninput="ingrAutocomplete(this)" onfocus="ingrAutocomplete(this)" onblur="setTimeout(()=>ingrCloseSuggest(this),150)" autocomplete="off">
      <div class="ingr-suggest"></div>
    </div>
    <input class="ingr-amount" placeholder="Qty" value="${esc(amount)}">
    <select class="ingr-unit"><option value="">unit</option>${unitOpts}</select>
    <button class="ingr-remove" type="button" onclick="this.closest('.ingr-row').remove()">×</button>`;
  (container||document.getElementById('ingr-list')).appendChild(div);
}
function addIngredientRow(){appendIngrRow('','','');}

// Live autocomplete from S.ingredientsLib (synced from Notion)
function ingrAutocomplete(inputEl){
  const wrap=inputEl.closest('.ingr-search-wrap');
  const sug=wrap.querySelector('.ingr-suggest');
  const lib=S.ingredientsLib||[];
  if(!lib.length){
    sug.innerHTML='<div class="ingr-suggest-empty">No ingredients synced yet — click ↻ Sync first.</div>';
    sug.classList.add('open');
    return;
  }
  const q=(inputEl.value||'').toLowerCase().trim();
  const matches=q?lib.filter(i=>(i.name||'').toLowerCase().includes(q)).slice(0,12):lib.slice(0,12);
  if(!matches.length){
    sug.innerHTML=`<div class="ingr-suggest-empty">No match for "${esc(q)}". Type a name and it'll be saved as-is, but won't link to nutrition data.</div>`;
    sug.classList.add('open');
    return;
  }
  sug.innerHTML=matches.map(i=>{
    const cat=i.category?`<span class="ingr-suggest-cat">${esc(i.category)}</span>`:'';
    const cal=i.cal_per_100g?`<span class="ingr-suggest-cal">${Math.round(i.cal_per_100g)} cal/100g</span>`:'';
    return `<div class="ingr-suggest-item" onmousedown="ingrPickSuggest(this,'${i.pageId}','${esc(i.name).replace(/'/g,"\\'")}')">
      <span class="ingr-suggest-name">${esc(i.name)}</span>${cat}${cal}
    </div>`;
  }).join('');
  sug.classList.add('open');
}
function ingrPickSuggest(item,pageId,name){
  const wrap=item.closest('.ingr-search-wrap');
  const input=wrap.querySelector('.ingr-name');
  input.value=name;
  input.dataset.ingPage=pageId;
  ingrCloseSuggest(input);
}
function ingrCloseSuggest(input){
  const wrap=input.closest('.ingr-search-wrap');
  if(!wrap)return;
  const sug=wrap.querySelector('.ingr-suggest');
  if(sug)sug.classList.remove('open');
}
function renderStepRows(steps){
  const c=document.getElementById('steps-list');c.innerHTML='';
  const list=Array.isArray(steps)?steps:[];
  if(!list.length){appendStepRow('',false,c);return;}
  for(const s of list){
    const text=typeof s==='string'?s:(s.text||'');
    const batchable=typeof s==='object'?!!s.batchable:false;
    appendStepRow(text,batchable,c);
  }
}
function appendStepRow(text,batchable,container){
  const c=container||document.getElementById('steps-list');
  const idx=c.children.length+1;
  const div=document.createElement('div');div.className='step-row';
  div.innerHTML=`<span class="step-num">${idx}</span><textarea class="step-text-input" rows="2" placeholder="What needs to be done…">${esc(text)}</textarea><label class="step-batch-toggle"><input type="checkbox" ${batchable?'checked':''}> batch ahead</label><button class="step-remove" type="button" onclick="this.closest('.step-row').remove();renumberSteps()">×</button>`;
  c.appendChild(div);
}
function addStepRow(){appendStepRow('',false);}
function renumberSteps(){document.querySelectorAll('.step-row').forEach((r,i)=>{const n=r.querySelector('.step-num');if(n)n.textContent=(i+1);});}
function saveRecipe(){
  const name=document.getElementById('ed-name').value.trim();
  if(!name){alert('Recipe name is required.');return;}
  const ingredients=[];
  document.querySelectorAll('.ingr-row').forEach(row=>{
    const ingInput=row.querySelector('.ingr-name');
    const n=ingInput?.value.trim();if(!n)return;
    ingredients.push({
      name:n,
      amount:row.querySelector('.ingr-amount')?.value.trim()||'',
      unit:row.querySelector('.ingr-unit')?.value.trim()||'',
      ingPageId:ingInput?.dataset?.ingPage||null, // links to Notion ingredient if picked from autocomplete
    });
  });
  const steps=[];
  document.querySelectorAll('.step-row').forEach(row=>{
    const t=row.querySelector('.step-text-input')?.value.trim();if(!t)return;
    steps.push({text:t,batchable:row.querySelector('.step-batch-toggle input')?.checked||false});
  });
  const section=document.getElementById('ed-section')?.value||'';
  const cuisine=document.getElementById('ed-cuisine')?.value||'';
  const tags=[];
  if(section)tags.push(section);
  if(cuisine)tags.push(cuisine);
  const recipe={id:edId||'r'+Date.now(),name,photo:edPhoto,
    section,cuisine,tags,
    servings:document.getElementById('ed-servings').value.trim(),
    time:document.getElementById('ed-time').value.trim(),
    notes:document.getElementById('ed-notes').value.trim(),
    ingredients,steps,
    pendingNotionPush:true, // marker for write-back later
  };
  // Preserve the Notion pageId if we're editing an existing recipe (so updates don't duplicate later)
  if(edId){const i=S.recipes.findIndex(r=>r.id===edId);if(i!==-1){recipe.pageId=S.recipes[i].pageId||null;S.recipes[i]=recipe;}}
  else S.recipes.push(recipe);
  save();closeRecipeEditorDirect();
  // Fire-and-forget write-back. Only push NEW recipes for now (Notion update is more involved); edits stay local until next sync.
  const cfg=getSyncCfg();
  if(cfg.workerUrl&&!recipe.pageId){
    notionPushRecipe(recipe).then(res=>{
      const idx=S.recipes.findIndex(r=>r.id===recipe.id);
      if(idx!==-1){S.recipes[idx].pageId=res.pageId;S.recipes[idx].pendingNotionPush=false;save();}
      const btn=document.getElementById('sync-btn');
      if(btn){const old=btn.textContent;btn.textContent='✓ pushed to Notion';setTimeout(()=>{btn.textContent=old||'↻ Sync'},2000);}
    }).catch(err=>{
      console.error('Recipe push failed:',err);
      alert('Saved locally, but Notion push failed: '+(err.message||err)+'\n\nIt will retry next time you click ↻ Sync.');
    });
  }
}
function deleteCurrentRecipe(){
  if(!edId||!confirm('Delete this recipe?'))return;
  S.recipes=S.recipes.filter(r=>r.id!==edId);
  for(const k of Object.keys(S.plan))S.plan[k]=(S.plan[k]||[]).filter(e=>e.recipeId!==edId);
  for(const w of Object.keys(S.weeklySnacks||{}))S.weeklySnacks[w]=(S.weeklySnacks[w]||[]).filter(e=>e.recipeId!==edId);
  save();closeRecipeEditorDirect();
}

// ===== WEEKLY RECIPES =====
function renderWeeklyRecipes(){
  const sun=getWeekSunday(S.weekOffset),sat=new Date(sun);sat.setDate(sat.getDate()+6);
  document.getElementById('wr-title').textContent=`This Week's Recipes — ${fmtDate(sun)} to ${fmtDate(sat)}`;
  const usedIds=new Set();
  for(let d=0;d<7;d++)for(const m of MEALS)(S.plan[pKey(S.weekOffset,d,m)]||[]).forEach(e=>usedIds.add(e.recipeId));
  for(const e of (S.weeklySnacks[S.weekOffset]||[]))usedIds.add(e.recipeId);
  const c=document.getElementById('weekly-recipes-list');
  if(!usedIds.size){c.innerHTML='<div class="empty-state"><div class="es-title">No recipes planned</div><p>Go to the Plan tab to assign meals for this week.</p></div>';return;}
  c.innerHTML=S.recipes.filter(r=>usedIds.has(r.id)).map(r=>{
    const photo=r.photo?`<img class="wr-photo" src="${r.photo}">`:`<div class="wr-photo-placeholder">${esc(r.name.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase())}</div>`;
    const ingrs=(r.ingredients||[]).map(i=>{
      const n=typeof i==='string'?i:i.name,a=typeof i==='object'?i.amount:'',u=typeof i==='object'?i.unit:'';
      return`<li>${[a,u,n].filter(Boolean).join(' ')}</li>`;
    }).join('');
    const steps=(r.steps||[]).map((s,i)=>{
      const t=typeof s==='string'?s:s.text,batchable=typeof s==='object'?s.batchable:false;
      const badge=batchable?`<span class="batch-badge">batch-able</span>`:'';
      return`<li><span class="wr-step-num">${i+1}</span><span style="flex:1">${esc(t)}</span>${badge}</li>`;
    }).join('');
    const meta=[r.servings&&r.servings+' servings',r.time].filter(Boolean).join(' · ');
    return`<div class="wr-recipe">
      <div class="wr-header" onclick="toggleWR(this)">${photo}
        <div class="wr-info"><div class="wr-name">${esc(r.name)}</div><div class="wr-meta">${meta}</div></div>
        <span class="wr-expand-icon">+</span></div>
      <div class="wr-body">
        ${ingrs?`<h4>Ingredients</h4><ul class="wr-ingr-list">${ingrs}</ul>`:''}
        ${steps?`<h4>Steps</h4><ol class="wr-steps-list">${steps}</ol>`:''}
        ${r.notes?`<div class="wr-notes">${esc(r.notes)}</div>`:''}
      </div></div>`;
  }).join('');
}
function toggleWR(hdr){
  const body=hdr.nextElementSibling,icon=hdr.querySelector('.wr-expand-icon');
  const open=body.classList.toggle('open');icon.textContent=open?'−':'+';
}

// ===== SHOPPING =====
function renderShopping(){generateShoppingList();renderInvSummary();}
function generateShoppingList(){
  const raw=[];
  for(let d=0;d<7;d++)for(const meal of MEALS){
    const rids=[...new Set((S.plan[pKey(S.weekOffset,d,meal)]||[]).map(e=>e.recipeId))];
    for(const rid of rids){
      const r=S.recipes.find(x=>x.id===rid);if(!r?.ingredients)continue;
      for(const i of r.ingredients){
        const name=typeof i==='string'?i:i.name;
        const amount=typeof i==='object'?i.amount:'';
        const unit=typeof i==='object'?i.unit:'';
        if(name)raw.push({name:name.trim(),amount,unit,recipe:r.name});
      }
    }
  }
  // Include weekly snacks
  for(const e of (S.weeklySnacks[S.weekOffset]||[])){
    const r=S.recipes.find(x=>x.id===e.recipeId);if(!r?.ingredients)continue;
    for(const i of r.ingredients){
      const name=typeof i==='string'?i:i.name;
      const amount=typeof i==='object'?i.amount:'';
      const unit=typeof i==='object'?i.unit:'';
      if(name)raw.push({name:name.trim(),amount,unit,recipe:r.name});
    }
  }
  const seen={},deduped=[];
  for(const i of raw){
    const k=i.name.toLowerCase();
    if(seen[k])seen[k].recipes.push(i.recipe);
    else{seen[k]={...i,recipes:[i.recipe]};deduped.push(seen[k]);}
  }
  const body=document.getElementById('shopping-list-body');
  if(!deduped.length){body.innerHTML='<div class="empty-state"><div class="es-title">Plan your week first</div><p>Shopping list generates automatically once meals are planned.</p></div>';return;}
  const allInv=[...S.inventory.freezer,...S.inventory.fridge,...S.inventory.pantry];
  const cats={Proteins:[],Produce:[],Pantry:[],Other:[]};
  for(const i of deduped){
    const n=i.name.toLowerCase();
    const autoStock=allInv.some(iv=>iv.name.toLowerCase().split(' ').some(w=>n.includes(w)&&w.length>3));
    const override=S.shopping[n];
    const inStock=override!==undefined?override:autoStock;
    const item={...i,inStock,shopKey:n};
    if(/beef|chicken|salmon|sardine|egg|sausage|ancestral|liver|heart|mince/.test(n))cats.Proteins.push(item);
    else if(/tomato|potato|onion|garlic|avocado|pepper|carrot|herb|parsley|cilantro|lemon|lime|berry|lettuce|kale|spinach|zucchini|apple|squash/.test(n))cats.Produce.push(item);
    else if(/flour|oil|salt|cumin|paprika|turmeric|cinnamon|coconut|almond|broth|can|vinegar|sauce|amino|honey|vanilla|baking|chia|flax|pumpkin|beet/.test(n))cats.Pantry.push(item);
    else cats.Other.push(item);
  }
  let html='';
  for(const[cat,items]of Object.entries(cats)){
    if(!items.length)continue;
    html+=`<div class="shop-category"><div class="shop-cat-title">${cat}</div>`;
    for(const item of items){
      const detail=[item.amount,item.unit].filter(Boolean).join(' ');
      html+=`<div class="shop-item">
        <input type="checkbox" ${item.inStock?'checked':''} onchange="toggleShopItem('${item.shopKey}',this.checked)">
        <label class="${item.inStock?'instock':''}">${esc(item.name)}${detail?` — <em style="color:var(--muted)">${esc(detail)}</em>`:''}</label>
        ${item.inStock?'<span class="in-stock-badge">have it</span>':''}
      </div>`;
    }
    html+='</div>';
  }
  body.innerHTML=html;
}
function toggleShopItem(key,inStock){S.shopping[key]=inStock;save();generateShoppingList();}
function renderInvSummary(){
  const el=document.getElementById('inv-summary');
  let html='';
  for(const[sec,label]of[['freezer','Freezer'],['fridge','Fridge'],['pantry','Pantry']]){
    const items=S.inventory[sec]||[];
    html+=`<div class="inv-section-mini"><h4>${label}</h4>`;
    items.slice(0,5).forEach(i=>html+=`<div class="inv-mini-item"><span>${esc(i.name)}</span><span class="inv-mini-amt">${esc(i.amount)} ${esc(i.unit)}</span></div>`);
    if(items.length>5)html+=`<div style="font-size:.72rem;color:var(--muted);padding:4px 0">+${items.length-5} more — see Inventory tab</div>`;
    html+='</div>';
  }
  el.innerHTML=html;
}

