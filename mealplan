async function testSyncConnection(){
  const out=document.getElementById('sync-test-result');
  out.textContent='Testing…';out.className='sync-test-result';
  const workerUrl=document.getElementById('sync-worker-url').value.trim().replace(/\/+$/,'');
  const syncKey=document.getElementById('sync-worker-key').value.trim();
  if(!workerUrl){out.textContent='Worker URL is required';out.className='sync-test-result err';return}
  try{
    const resp=await fetch(`${workerUrl}/v1/databases/${NOTION_DB.ingredients}`,{
      method:'GET',headers:{'Content-Type':'application/json',...(syncKey?{'X-Sync-Key':syncKey}:{})},
    });
    if(resp.status===401){out.textContent='✗ Sync key wrong (worker rejected)';out.className='sync-test-result err';return}
    if(!resp.ok){const t=await resp.text();out.textContent=`✗ Notion replied ${resp.status}: ${t.slice(0,200)}`;out.className='sync-test-result err';return}
    const data=await resp.json();
    out.textContent=`✓ Connected. Database "${(data.title||[]).map(t=>t.plain_text).join('')}" reachable.`;
    out.className='sync-test-result ok';
  }catch(err){out.textContent=`✗ ${err.message||err}`;out.className='sync-test-result err';}
}

async function notionFetch(path,init={}){
  const cfg=getSyncCfg();
  if(!cfg.workerUrl)throw new Error('Open ⚙ Settings and paste your Worker URL first.');
  const headers={'Content-Type':'application/json',...(init.headers||{})};
  if(cfg.syncKey)headers['X-Sync-Key']=cfg.syncKey;
  const resp=await fetch(`${cfg.workerUrl}/${path.replace(/^\/+/,'')}`,{...init,headers});
  if(!resp.ok){const t=await resp.text();throw new Error(`Notion ${resp.status}: ${t.slice(0,300)}`);}
  return resp.json();
}
async function notionQueryAll(dbId){
  let results=[],cursor=null;
  do{
    const body=cursor?{start_cursor:cursor,page_size:100}:{page_size:100};
    const data=await notionFetch(`v1/databases/${dbId}/query`,{method:'POST',body:JSON.stringify(body)});
    results=results.concat(data.results||[]);
    cursor=data.has_more?data.next_cursor:null;
  }while(cursor);
  return results;
}

// Notion property helpers
function nTitle(p){return ((p&&p.title)||[]).map(t=>t.plain_text||'').join('').trim();}
function nText(p){return ((p&&p.rich_text)||[]).map(t=>t.plain_text||'').join('');}
function nNumber(p){return p?(p.number==null?null:p.number):null;}
function nSelect(p){return p&&p.select?p.select.name:null;}
function nMulti(p){return ((p&&p.multi_select)||[]).map(o=>o.name);}
function nCheckbox(p){return !!(p&&p.checkbox);}
function nRelation(p){return ((p&&p.relation)||[]).map(r=>r.id);}
function nRollupNumber(p){return p&&p.rollup&&p.rollup.number!=null?p.rollup.number:null;}
// Notion file URLs are signed S3 links that expire after ~1 hour. So instead of storing the
// raw signed URL, we store a stable Worker proxy URL — the Worker re-fetches the page on each
// hit and 302-redirects to whatever URL Notion is currently serving. External (Unsplash etc.)
// URLs are returned as-is.
function nCover(page){
  const c=page.cover;if(!c)return null;
  if(c.external?.url)return c.external.url;
  if(c.file?.url){
    const cfg=getSyncCfg();
    if(cfg.workerUrl)return `${cfg.workerUrl.replace(/\/+$/,'')}/cover/${page.id}`;
    return c.file.url; // fallback — will expire, but better than nothing
  }
  return null;
}

function notionParseIngredient(page){
  const p=page.properties||{};
  return {
    pageId:page.id,
    name:nTitle(p['Ingredient']),
    category:nSelect(p['Category']),
    cal_per_100g:nNumber(p['Calories per 100g']),
    protein_per_100g:nNumber(p['Protein per 100g (g)']),
    carbs_per_100g:nNumber(p['Carbs per 100g (g)']),
    fat_per_100g:nNumber(p['Fat per 100g (g)']),
    fiber_per_100g:nNumber(p['Fiber per 100g (g)']),
    g_per_tsp:nNumber(p['Grams per tsp']),
    g_per_tbsp:nNumber(p['Grams per tbsp']),
    g_per_cup:nNumber(p['Grams per cup']),
    g_per_piece:nNumber(p['Grams per piece']),
    paleo:nCheckbox(p['Paleo']),
    keto:nCheckbox(p['Keto-friendly']),
    reactive_for:nRelation(p['Reactive For']),
    healing:nText(p['Healing Benefits']),
    compounds:nMulti(p['Key Compounds']),
    notes:nText(p['Notes']),
  };
}
function notionParseProfile(page){
  const p=page.properties||{};
  return {pageId:page.id,name:nTitle(p['Name']),age:nNumber(p['Age']),
    high:nMulti(p['High Sensitivities']),mod:nMulti(p['Moderate Sensitivities']),
    calorie_target:nNumber(p['Calorie Target']),protein_target:nNumber(p['Protein Target (g)'])};
}
function notionParseRecipe(page,components,ingredientsByPid,profilesByPid){
  const p=page.properties||{};
  const recipeId=page.id;
  // Pull the components for this recipe
  const myComps=components.filter(c=>{
    const recRels=nRelation((c.properties||{})['Recipe']);
    return recRels.includes(recipeId);
  });
  const ingredients=myComps.map(c=>{
    const cp=c.properties||{};
    const ingPid=(nRelation(cp['Ingredient'])||[])[0];
    const ing=ingPid?ingredientsByPid[ingPid]:null;
    return {
      name:ing?ing.name:nTitle(cp['Component']),
      amount:nNumber(cp['Amount'])||'',
      unit:nSelect(cp['Unit'])||'',
      grams:nNumber(cp['Grams']),
      ingPageId:ingPid,
    };
  });
  // Steps stored as text — split by newline, strip "1) " prefixes, mark batchable=false default
  const stepsText=nText(p['Steps']);
  const steps=stepsText?stepsText.split(/\n+/).map(l=>l.replace(/^\d+[\.\)]\s*/,'').trim()).filter(Boolean).map(t=>({text:t,batchable:false})):[];
  // tags: include Section + Cuisine for now (used by TOC classifier as fallback)
  const tags=[];
  const sec=nSelect(p['Section']);if(sec)tags.push(sec);
  const cuis=nSelect(p['Cuisine']);if(cuis)tags.push(cuis);
  if(nCheckbox(p['Batchable']))tags.push('Batch');
  return {
    id:recipeId.replace(/-/g,'').slice(0,16), // short id for HTML refs
    pageId:recipeId,
    name:nTitle(p['Recipe']),
    photo:nCover(page),
    section:sec,cuisine:cuis,
    servings:nNumber(p['Servings'])||'',
    time:[nNumber(p['Prep Time (min)']),nNumber(p['Cook Time (min)'])].filter(x=>x).map(n=>`${n} min`).join(' / ')||'',
    tags,steps,notes:nText(p['Notes']),
    ingredients,
    total_calories:nRollupNumber(p['Total Calories']),
    total_protein:nRollupNumber(p['Total Protein (g)']),
    total_carbs:nRollupNumber(p['Total Carbs (g)']),
    total_fat:nRollupNumber(p['Total Fat (g)']),
    total_fiber:nRollupNumber(p['Total Fiber (g)']),
  };
}
function notionParseSeasonal(page){
  const p=page.properties||{};
  return {name:nTitle(p['Produce']),type:nSelect(p['Type']),
    months:nMulti(p['Peak Months']),region:nSelect(p['Region'])};
}
function notionParseInventoryItem(page){
  const p=page.properties||{};
  return {id:page.id,name:nTitle(p['Item']),location:nSelect(p['Location'])||'pantry',
    amount:String(nNumber(p['Amount'])||''),unit:nSelect(p['Unit'])||''};
}

async function notionGetDatabase(dbId){
  return await notionFetch(`v1/databases/${dbId}`,{method:'GET'});
}
function extractSelectOptions(dbSchema,propName){
  const p=dbSchema?.properties?.[propName];
  if(!p)return[];
  if(p.select)return (p.select.options||[]).map(o=>o.name);
  if(p.multi_select)return (p.multi_select.options||[]).map(o=>o.name);
  return[];
}

// ===== WRITE-BACK: HTML → Notion =====
// Push a recipe (and its Components rows) to Notion. Returns the new recipe page id.
async function notionPushRecipe(recipe){
  const cfg=getSyncCfg();
  if(!cfg.workerUrl)throw new Error('Settings → paste Worker URL first.');

  // 1) Build the Recipe page properties using only options Notion already knows about
  const opts=S.notionOptions||{};
  const sectionOk=recipe.section&&(opts.recipeSection||[]).includes(recipe.section);
  const cuisineOk=recipe.cuisine&&(opts.recipeCuisine||[]).includes(recipe.cuisine);
  const servingsNum=Number(recipe.servings)||null;
  // time format we store locally is "10 min / 25 min" — split back into prep/cook
  const timeMatch=String(recipe.time||'').match(/(\d+)\s*min(?:\s*\/\s*(\d+)\s*min)?/i);
  const prep=timeMatch?Number(timeMatch[1]):null;
  const cook=timeMatch&&timeMatch[2]?Number(timeMatch[2]):null;
  // Steps: stored as a single rich_text field, one numbered line per step
  const stepsText=(recipe.steps||[]).map((s,i)=>`${i+1}) ${typeof s==='string'?s:s.text}`).join('\n');
  // Batchable = any step marked batchable
  const batchable=(recipe.steps||[]).some(s=>typeof s==='object'&&s.batchable);

  const recipeProps={
    'Recipe':{title:[{text:{content:recipe.name||'Untitled'}}]},
    ...(sectionOk?{'Section':{select:{name:recipe.section}}}:{}),
    ...(cuisineOk?{'Cuisine':{select:{name:recipe.cuisine}}}:{}),
    ...(servingsNum!=null?{'Servings':{number:servingsNum}}:{}),
    ...(prep!=null?{'Prep Time (min)':{number:prep}}:{}),
    ...(cook!=null?{'Cook Time (min)':{number:cook}}:{}),
    ...(stepsText?{'Steps':{rich_text:[{text:{content:stepsText.slice(0,1900)}}]}}:{}),
    ...(recipe.notes?{'Notes':{rich_text:[{text:{content:String(recipe.notes).slice(0,1900)}}]}}:{}),
    'Batchable':{checkbox:!!batchable},
  };

  const pagePayload={
    parent:{database_id:NOTION_DB.recipes},
    properties:recipeProps,
    ...(recipe.photo&&/^https?:/.test(recipe.photo)?{cover:{type:'external',external:{url:recipe.photo}}}:{}),
  };

  // 2) Create the recipe page
  const newPage=await notionFetch('v1/pages',{method:'POST',body:JSON.stringify(pagePayload)});
  const recipePageId=newPage.id;

  // 3) Create one Component page per ingredient row
  const unitList=opts.componentUnit||[];
  const compErrors=[];
  for(const ing of (recipe.ingredients||[])){
    if(!ing||!ing.name)continue;
    const amt=Number(ing.amount);
    const unitOk=ing.unit&&unitList.includes(ing.unit);
    const compProps={
      'Component':{title:[{text:{content:`${recipe.name} — ${ing.name}`.slice(0,180)}}]},
      'Recipe':{relation:[{id:recipePageId}]},
      ...(ing.ingPageId?{'Ingredient':{relation:[{id:ing.ingPageId}]}}:{}),
      ...(Number.isFinite(amt)?{'Amount':{number:amt}}:{}),
      ...(unitOk?{'Unit':{select:{name:ing.unit}}}:{}),
    };
    try{
      await notionFetch('v1/pages',{method:'POST',body:JSON.stringify({
        parent:{database_id:NOTION_DB.components},properties:compProps,
      })});
    }catch(e){compErrors.push(`${ing.name}: ${e.message||e}`);}
  }
  if(compErrors.length){console.warn('Some components failed to push:',compErrors);}

  return {pageId:recipePageId,componentErrors:compErrors};
}

// Push every recipe currently flagged pendingNotionPush. Called from saveRecipe and the sync button.
async function flushPendingRecipes(){
  const pending=(S.recipes||[]).filter(r=>r.pendingNotionPush);
  if(!pending.length)return {pushed:0,failed:0};
  let pushed=0,failed=0;
  for(const r of pending){
    try{
      const res=await notionPushRecipe(r);
      r.pageId=res.pageId;
      r.pendingNotionPush=false;
      pushed++;
    }catch(e){console.error('Push failed for',r.name,e);failed++;}
  }
  save();
  return {pushed,failed};
}

// Sync state — used by both manual and automatic syncs to avoid overlapping requests
let _syncInFlight=false;
async function notionSyncAll(opts={}){
  const silent=!!opts.silent;
  const cfg=getSyncCfg();
  if(!cfg.workerUrl){
    if(silent)return; // skip silently if not configured (first-run on a hosted page)
    openSyncSettings();return;
  }
  if(_syncInFlight)return; // never run two syncs at once
  _syncInFlight=true;
  const btn=document.getElementById('sync-btn');
  if(btn&&!silent){btn.classList.add('syncing');btn.textContent='Syncing…';}
  try{
    // 0) Retry any recipes we couldn't push earlier (offline, transient error, schema fix)
    const flushed=await flushPendingRecipes();
    if(flushed.pushed)console.log(`Pushed ${flushed.pushed} pending recipe(s) to Notion`);
    const [profiles,ingredients,recipes,components,seasonal,inventory,recipesDB,compsDB,inventoryDB]=await Promise.all([
      notionQueryAll(NOTION_DB.profiles),
      notionQueryAll(NOTION_DB.ingredients),
      notionQueryAll(NOTION_DB.recipes),
      notionQueryAll(NOTION_DB.components),
      notionQueryAll(NOTION_DB.seasonalProduce),
      notionQueryAll(NOTION_DB.inventory),
      notionGetDatabase(NOTION_DB.recipes),
      notionGetDatabase(NOTION_DB.components),
      notionGetDatabase(NOTION_DB.inventory),
    ]);
    // Capture dropdown option lists straight from the Notion schema
    S.notionOptions={
      recipeSection:extractSelectOptions(recipesDB,'Section'),
      recipeCuisine:extractSelectOptions(recipesDB,'Cuisine'),
      componentUnit:extractSelectOptions(compsDB,'Unit'),
      inventoryLocation:extractSelectOptions(inventoryDB,'Location'),
      inventoryCategory:extractSelectOptions(inventoryDB,'Category'),
      inventoryUnit:extractSelectOptions(inventoryDB,'Unit'),
    };
    const ingsParsed=ingredients.map(notionParseIngredient);
    const ingByPid=Object.fromEntries(ingsParsed.map(i=>[i.pageId,i]));
    const profsParsed=profiles.map(notionParseProfile);
    const profByPid=Object.fromEntries(profsParsed.map(p=>[p.pageId,p]));
    const recipesParsed=recipes.map(r=>notionParseRecipe(r,components,ingByPid,profByPid));
    const seasonalParsed=seasonal.map(notionParseSeasonal);
    // Bucket inventory by location
    const inv={freezer:[],fridge:[],pantry:[]};
    for(const it of inventory){
      const item=notionParseInventoryItem(it);
      const loc=(item.location||'pantry').toLowerCase();
      (inv[loc]||(inv['pantry'])).push(item);
    }
    S.recipes=recipesParsed;
    S.ingredientsLib=ingsParsed;
    S.profiles=profsParsed;
    S.seasonalProduce=seasonalParsed;
    S.inventory=inv;
    S.lastSync=Date.now();
    save();
    if(btn&&!silent){
      btn.textContent=`✓ ${ingsParsed.length} ings, ${recipesParsed.length} recipes`;
      setTimeout(()=>{btn.classList.remove('syncing');btn.textContent=syncBtnIdleLabel()},2200);
    }
    if(currentPage==='plan')renderPlanPage();
    if(currentPage==='book'&&typeof bookRender==='function')bookRender();
  }catch(err){
    console.error('Sync error:',err);
    if(btn&&!silent){
      btn.classList.remove('syncing');
      btn.textContent='✗ failed';
      setTimeout(()=>{btn.textContent=syncBtnIdleLabel()},2500);
    }
    if(!silent)alert('Sync failed: '+(err.message||err));
  }finally{
    _syncInFlight=false;
  }
}

function syncBtnIdleLabel(){
  if(!S.lastSync)return'↻ Sync';
  const ago=Math.round((Date.now()-S.lastSync)/60000);
  if(ago<1)return'✓ just now';
  if(ago<60)return`✓ ${ago}m ago`;
  return'↻ Sync';
}

S=migrateState(loadState());
// Always open on the current week + today (avoids "stuck in past month" if user navigated away last session)
S.weekOffset=0;
focusedDay=new Date().getDay();
save();
updateWeekLabel();
renderPlanPage();

// Re-check date every 5 minutes — if the calendar day rolled over, refresh the view so "today" stays accurate
setInterval(()=>{
  const newDay=new Date().getDay();
  if(newDay!==focusedDay && S.weekOffset===0){
    focusedDay=newDay;
    if(currentPage==='plan')renderPlanPage();
  }
  updateWeekLabel();
},5*60*1000);

// ===== AUTO-SYNC =====
// Philosophy: only sync when *content* is actually stale, never on a fixed timer.
// Image URL expiry is handled separately and transparently by the Worker's
// /cover/<pageId> proxy + edge cache, so it doesn't drive sync frequency.
//
// Sync exists to pick up changes you make in Notion (new recipes, edits to
// existing ones, etc.). For a meal planner, editing happens in bursts rather
// than continuously, so a single 15-minute threshold for both load and focus
// covers the realistic cases without sync-thrashing on every tab switch.
//
// Sync triggers:
//   1) First ever load (no S.lastSync yet) → sync once.
//   2) Page load OR tab regaining focus AND data is older than STALE_MS → sync.
//   3) After saving a recipe (handled in saveRecipe; pulls fresh state).
//   4) Manual click on the sync button.
//
// Notably absent: no setInterval. A backgrounded tab does nothing. A focused
// tab does nothing if the user isn't switching context.
const STALE_MS = 15*60*1000; // 15 min — long enough to skip incidental tab-switches,
                             // short enough that "I edited in Notion, switch back" works

function maybeAutoSync(reason){
  const cfg=getSyncCfg();
  if(!cfg.workerUrl)return;
  const last=S.lastSync||0;
  if(last&&Date.now()-last<STALE_MS)return; // data is fresh enough — skip
  notionSyncAll({silent:true});
}

// Initial check — runs after the first paint so cached state shows instantly
setTimeout(()=>maybeAutoSync('load'),250);

// When the tab regains focus or visibility, sync only if data is actually stale
window.addEventListener('focus',()=>maybeAutoSync('focus'));
document.addEventListener('visibilitychange',()=>{if(!document.hidden)maybeAutoSync('focus')});

// Update the sync button label every minute so "✓ 3m ago" actually counts up.
// (This is a UI render — no network calls.)
setInterval(()=>{
  const btn=document.getElementById('sync-btn');
  if(btn&&!btn.classList.contains('syncing'))btn.textContent=syncBtnIdleLabel();
},60*1000);
</script>
