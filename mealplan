function renderBatchPopupBody(){
  // PLANNED: steps placed on THIS batch day
  // ELIGIBLE: batch-able steps from THIS week + NEXT week, not yet placed anywhere (or placed on another day)
  const here=S.batchPlacements[bKey(S.weekOffset,currentBatchDay)]||[];
  const allPlacedSet=new Set();
  for(const v of Object.values(S.batchPlacements||{}))for(const p of v)allPlacedSet.add(p);

  // Gather eligible: scan current week and next week's plan (all upcoming meals)
  const eligible=[];
  for(let wo=S.weekOffset; wo<=S.weekOffset+1; wo++){
    for(let d=0;d<7;d++){
      // Skip past dates BEFORE the batch day in current week (batch must be ≤ 7 days before meal AND ≥ batch day)
      // We allow anything in the next 7 days from the batch day
      for(const meal of MEALS){
        const entries=S.plan[pKey(wo,d,meal)]||[];
        const rids=[...new Set(entries.map(e=>e.recipeId))];
        for(const rid of rids){
          const r=S.recipes.find(x=>x.id===rid);
          if(!r||!Array.isArray(r.steps))continue;
          r.steps.forEach((step,idx)=>{
            const obj=typeof step==='string'?{text:step,batchable:false}:step;
            if(!obj.batchable)return;
            const pid=pidOf(rid,idx,wo,d,meal);
            // Within 7-day window from this batch day
            const batchDate=getWeekSunday(S.weekOffset);batchDate.setDate(batchDate.getDate()+currentBatchDay);
            const mealDate=getWeekSunday(wo);mealDate.setDate(mealDate.getDate()+d);
            const diffDays=Math.round((mealDate-batchDate)/86400000);
            if(diffDays<=0||diffDays>7)return; // must be 1-7 days ahead of the meal
            eligible.push({pid,text:obj.text,recipe:r.name,recipeId:rid,stepIdx:idx,wo,d,meal,mealDate});
          });
        }
      }
    }
  }
  // Split: planned-here vs other
  const plannedHere=here.map(pid=>{
    const m=pid.match(/^(.+)@(\d+)@(-?\d+)\|(\d+)\|([a-z]+)$/);
    if(!m)return null;
    const r=S.recipes.find(x=>x.id===m[1]);
    if(!r||!Array.isArray(r.steps))return null;
    const step=r.steps[Number(m[2])];
    if(!step)return null;
    const obj=typeof step==='string'?{text:step,batchable:true}:step;
    return{pid,text:obj.text,recipe:r.name,recipeId:m[1],stepIdx:Number(m[2]),wo:Number(m[3]),d:Number(m[4]),meal:m[5]};
  }).filter(Boolean);
  const plannedHereSet=new Set(plannedHere.map(x=>x.pid));
  const others=eligible.filter(e=>!plannedHereSet.has(e.pid));

  let html=`<div class="batch-section" id="batch-here-zone" ondragover="event.preventDefault();this.classList.add('drop-target')" ondragleave="this.classList.remove('drop-target')" ondrop="handleBatchPopupDrop(event)">
    <div class="batch-section-title">Planned for this batch day</div>`;
  if(!plannedHere.length){
    html+='<div class="batch-empty">Nothing planned yet — drag a step here, or check one below.</div>';
  } else {
    for(const s of plannedHere){
      const sun=getWeekSunday(s.wo),dd=new Date(sun);dd.setDate(sun.getDate()+s.d);
      html+=`<div class="batch-step-row planned-here" draggable="true" data-pid="${s.pid}" ondragstart="batchDragStart(event,'${s.pid}')" ondragend="batchDragEnd(event)">
        <input type="checkbox" class="batch-step-check" checked onchange="toggleBatchPlacement('${s.pid}',false)">
        <div class="batch-step-info">
          <div class="batch-step-text">${esc(s.text)}</div>
          <div class="batch-step-meta">
            <span class="batch-step-pill recipe">${esc(s.recipe)}</span>
            <span class="batch-step-pill">for ${DAY_FULL[s.d]} · ${MEAL_LABEL[s.meal]}</span>
            <span class="batch-step-pill">${fmtDate(dd)}</span>
          </div>
        </div>
      </div>`;
    }
  }
  html+=`</div><div class="batch-section">
    <div class="batch-section-title">Available batch-able steps (next 7 days)</div>`;
  if(!others.length){
    html+='<div class="batch-empty">No upcoming batch-able steps. Mark recipe steps as "batch ahead" in the recipe editor.</div>';
  } else {
    // Group by recipe / day
    others.sort((a,b)=>a.mealDate-b.mealDate);
    for(const s of others){
      const dd=s.mealDate;
      const isPlacedElsewhere=allPlacedSet.has(s.pid);
      html+=`<div class="batch-step-row" draggable="true" data-pid="${s.pid}" ondragstart="batchDragStart(event,'${s.pid}')" ondragend="batchDragEnd(event)">
        <input type="checkbox" class="batch-step-check" ${isPlacedElsewhere?'disabled':''} onchange="toggleBatchPlacement('${s.pid}',this.checked)">
        <div class="batch-step-info">
          <div class="batch-step-text">${esc(s.text)}${isPlacedElsewhere?' <em style="color:var(--muted);font-size:.78rem">(planned on another batch day)</em>':''}</div>
          <div class="batch-step-meta">
            <span class="batch-step-pill recipe">${esc(s.recipe)}</span>
            <span class="batch-step-pill">for ${DAY_FULL[s.d]} · ${MEAL_LABEL[s.meal]}</span>
            <span class="batch-step-pill">${fmtDate(dd)}</span>
          </div>
        </div>
      </div>`;
    }
  }
  html+='</div>';
  document.getElementById('batch-popup-body').innerHTML=html;
}

function toggleBatchPlacement(pid,placeHere){
  const k=bKey(S.weekOffset,currentBatchDay);
  if(!S.batchPlacements[k])S.batchPlacements[k]=[];
  // remove from any other batch day first if placeHere=true
  if(placeHere){
    for(const otherK of Object.keys(S.batchPlacements||{})){
      S.batchPlacements[otherK]=(S.batchPlacements[otherK]||[]).filter(x=>x!==pid);
    }
    if(!S.batchPlacements[k].includes(pid))S.batchPlacements[k].push(pid);
  } else {
    S.batchPlacements[k]=S.batchPlacements[k].filter(x=>x!==pid);
  }
  // cleanup empty
  for(const okk of Object.keys(S.batchPlacements))if(!S.batchPlacements[okk].length)delete S.batchPlacements[okk];
  save();renderBatchPopupBody();
}

// Drag-and-drop
let dragPid=null;
function batchDragStart(evt,pid){
  dragPid=pid;evt.dataTransfer.effectAllowed='move';
